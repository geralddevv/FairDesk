<% layout('/layout/boilerplate') -%>

<div class="main-content">
  <div>
    <div class="span-full form-subheading gap" style="margin-bottom: 1rem;">
      <div>
        <h1>Edit User Details</h1>
      </div>
    </div>       

    <form action="/fairdesk/form/edit/user/<%= user._id %>" method="post" class="span-full needs-validation" style="display: grid; grid-template-columns: repeat(32, 1fr); gap: 1.25rem;" autocomplete="off" novalidate>
    
      <div class="span-full form-subheading">
        <h1>Client Reference</h1>
      </div>

      <div class="span-seven">
        <label for="user-client-id">Client Id</label>
        <input id="user-client-id" class="form-control input-tag" value="<%= user.clientId %>" disabled />
      </div>    

      <div class="span-six">
        <label for="client-name">Client Name</label>
        <input class="form-control input-tag" value="<%= user.clientName %>" disabled />
      </div>

      <div class="span-six">
        <label for="client-type">Client Type</label>
        <input class="form-control input-tag" value="<%= user.clientType %>" disabled />
      </div>

      <div class="span-six">
        <label for="ho-location">H/O Location</label>
        <input type="text" id="username-ho-location" class="form-control input-tag" name="hoLocation" value="<%= user.hoLocation %>" placeholder="Enter H/O Location" required />
      </div>

      <div class="span-seven">
        <label for="account-head">Account Head</label>
        <input type="text" id="username-account-head" class="form-control input-tag" name="accountHead" value="<%= user.accountHead %>" placeholder="Enter Account Head" required />
      </div>    

      <div class="span-full form-subheading">
        <h1>Username Information</h1>
      </div>

      <div class="span-seven">
        <label for="user-name">Username</label>
        <input type="text" id="user-name" class="form-control input-tag" name="userName" value="<%= user.userName %>" placeholder="Enter Username" required />
      </div>

      <div class="span-six">
        <label for="user-location">Location</label>
        <input type="text" id="user-location" class="form-control input-tag" name="userLocation" value="<%= user.userLocation %>" placeholder="Enter Location" required />
      </div>

      <div class="span-six">
        <label for="user-department">Department</label>
        <input type="text" id="user-department" class="form-control input-tag" name="userDepartment" value="<%= user.userDepartment %>" placeholder="Enter Department" required />
      </div>

      <div class="span-six">
        <label for="user-contact-no">Contact No</label>
        <input type="text" id="user-contact-no" class="form-control input-tag" name="userContact" value="<%= user.userContact %>" placeholder="Enter Contact No" required />
      </div>

      <div class="span-seven">
        <label for="user-email">Email</label>
        <input type="email" id="user-email" class="form-control" name="userEmail" value="<%= user.userEmail %>" placeholder="Enter Email" required />
      </div>

      <div class="span-full">
        <label for="dispatch-address">Address</label>
        <textarea id="dispatch-address" class="form-control input-tag" name="dispatchAddress" placeholder="Enter Address" rows="3" style="border: 1px solid #044A78; resize: none;" required><%= user.dispatchAddress %></textarea>
      </div>

      <div class="span-full form-subheading">
        <h1>Dispatch Details</h1>
      </div>

      <!-- We keep the same JS logic from your app to switch between Transport / Self Dispatch -->
      <div class="span-full form-subheading gap" style="cursor: pointer;">
        <div class="hardware <%= !user.SelfDispatch ? 'active' : '' %>" id="transport-tab">
          <h1>Transport</h1>
        </div>
        <div class="software <%= user.SelfDispatch ? 'active' : '' %>" id="self-dispatch-tab">
          <h1>Self Dispatch</h1>
        </div>
      </div>       

      <div class="span-full hardware-options" style="display: <%= !user.SelfDispatch ? 'grid' : 'none' %>; grid-template-columns: repeat(32, 1fr); gap: 1.25rem;">
        <div class="span-six">
          <label for="transport-name">Name</label>
          <input type="text" id="transport-name" class="form-control input-tag" name="transportName" value="<%= user.transportName || '' %>" placeholder="Enter Transport Name" />
        </div>

        <div class="span-five">
          <label for="transport-contact">Contact</label>
          <input type="text" id="transport-contact" class="form-control input-tag" name="transportContact" value="<%= user.transportContact || '' %>" placeholder="Enter Transport Contact" />
        </div>

        <div class="span-five">
          <label for="drop-location">Drop Location</label>
          <input type="text" id="drop-location" class="form-control input-tag" name="dropLocation" value="<%= user.dropLocation || '' %>" placeholder="Enter Drop Location" />
        </div>

        <div class="span-five">
          <label for="delivery-mode">Delivery Mode</label>
          <select name="deliveryMode" id="delivery-mode" class="form-control select-tag">
            <option value="" disabled <%= !user.deliveryMode ? 'selected' : '' %>>Select</option>
            <option value="DOOR" <%= user.deliveryMode === 'DOOR' ? 'selected' : '' %>>DOOR</option>
            <option value="GODOWN" <%= user.deliveryMode === 'GODOWN' ? 'selected' : '' %>>GODOWN</option>
          </select>
        </div>

        <div class="span-five">
          <label for="delivery-location">Delivery Loc</label>
          <input type="text" id="delivery-location" class="form-control input-tag" name="deliveryLocation" value="<%= user.deliveryLocation || '' %>" placeholder="Enter Delivery Location" />
        </div>

        <div class="span-six">
          <label for="payment">Payment</label>
          <select name="clientPayment" id="payment" class="form-control select-tag">
            <option value="" disabled <%= !user.clientPayment ? 'selected' : '' %>>Select</option>
            <option value="PAY" <%= user.clientPayment === 'PAY' ? 'selected' : '' %>>PAY</option>
            <option value="TO PAY" <%= user.clientPayment === 'TO PAY' ? 'selected' : '' %>>TO PAY</option>
          </select>
        </div>      
      </div>

      <div class="span-full software-options" style="display: <%= user.SelfDispatch ? 'grid' : 'none' %>; grid-template-columns: repeat(32, 1fr); gap: 1.25rem;">
        <!-- If Self Dispatch is selected, this hidden input ensures a truthy value is sent over POST -->
        <input type="hidden" id="self-dispatch-value" name="SelfDispatch" value="<%= user.SelfDispatch || '' %>" />
        <input type="text" id="self-dispatch-display" class="form-control input-tag span-full" value="Self Dispatch" readonly />
      </div>

      <div class="span-full btn-grp">
        <button class="submit-btn" type="submit">Update User Details</button>
      </div>
    </form>
  </div>
</div>

<script>
  // Simple Tab Switching Logic for Edit form
  document.addEventListener("DOMContentLoaded", () => {
    const transportTab = document.getElementById("transport-tab");
    const selfDispatchTab = document.getElementById("self-dispatch-tab");
    const hardwareOptions = document.querySelector(".hardware-options");
    const softwareOptions = document.querySelector(".software-options");
    const selfDispatchInput = document.getElementById("self-dispatch-value");
    
    // Get all transport inputs
    const transportInputs = hardwareOptions.querySelectorAll("input, select");

    function updateTransportInputs(isTransport) {
      transportInputs.forEach(input => {
        if (isTransport) {
          input.disabled = false;
          input.required = true;
        } else {
          input.disabled = true;
          input.required = false;
        }
      });
    }

    // Initialize state
    updateTransportInputs(!selfDispatchTab.classList.contains("active"));

    transportTab.addEventListener("click", () => {
      transportTab.classList.add("active");
      selfDispatchTab.classList.remove("active");
      hardwareOptions.style.display = "grid";
      softwareOptions.style.display = "none";
      selfDispatchInput.value = ""; // Clear self dispatch when transport selected
      updateTransportInputs(true);
    });

    selfDispatchTab.addEventListener("click", () => {
      selfDispatchTab.classList.add("active");
      transportTab.classList.remove("active");
      softwareOptions.style.display = "grid";
      hardwareOptions.style.display = "none";
      selfDispatchInput.value = "Self Dispatch"; // Set value when selected
      updateTransportInputs(false);
    });
  });
</script>
