<% layout('/layout/boilerplate') -%>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
    <div class="indi-head">
      <h1 id="page-title">
          <% if(jsonData.length > 0) { %>
            TTR — <%= jsonData[0].clientName %>
          <% } else { %>
            TTR View
          <% } %>
        </h1>
        <div class="download-btns" style="display: flex; gap: 10px; align-items: center">
          <a
            href="/fairdesk/form/ttr"
            class="header-action-btn"
            style="
              height: 30px;
              padding: 0 14px;
              background: #f0f0f0;
              color: #044a78;
              border-radius: 6px;
              text-decoration: none;
              font-size: 14px;
              font-weight: 500;
              display: inline-flex;
              align-items: center;
              gap: 6px;
              transition: all 0.2s;
              box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            "
          >
            <i class="fa-solid fa-plus"></i>
            <span>Add TTR</span>
          </a>

          <div class="download-selector" id="downloadSelector">
            <button class="download-selector__trigger" style="height: 30px; display: flex; align-items: center; padding: 0 12px; border: 1.5px solid #e2e8f0; border-radius: 6px; background: #fff; font-size: 14px; font-weight: 500; cursor: pointer;">
              <span>
                <i class="fa-solid fa-file-arrow-down"></i>
                <span class="download-typo">Download</span>
              </span>
              <i class="fas fa-chevron-down download-selector__trigger-icon" style="font-size: 12px; margin-left: 6px;"></i>
            </button>
            <div class="download-selector__menu" id="downloads">
              <span class="download-selector__option" id="download-pdf">
                <i class="fas fa-file-pdf download-selector__option-icon"></i>
                <span>PDF</span>
              </span>
              <span class="download-selector__option" id="download-xlsx">
                <i class="fas fa-file-excel download-selector__option-icon"></i>
                <span>Excel</span>
              </span>
            </div>
          </div>
      </div>
    </div>

    <div class="table-spinner"><div class="spinner-circle"></div></div>
    <div id="master-table" class="tabulator tabulator-modern"></div>
</div>

  <!-- Tabulator JS -->
  <script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>

  <form id="deleteBindingForm" method="POST" style="display:none;"></form>
  <div class="logout-modal" id="deleteBindingModal" aria-hidden="true">
    <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteBindingTitle">
      <h2 class="logout-title" id="deleteBindingTitle">Remove binding?</h2>
      <p class="logout-message" id="deleteBindingMessage">This will permanently delete this TTR record.</p>
      <div class="logout-buttons">
        <button type="button" class="logout-btn logout-cancel" onclick="closeDeleteModal()">Cancel</button>
        <button type="button" class="logout-btn logout-confirm" onclick="confirmDelete()">Delete</button>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/file-saver@2.0.5/dist/FileSaver.min.js"></script>

  <script>
    // ================= DOWNLOAD DROPDOWN =================
    const downloadSelector = document.getElementById("downloadSelector");
    const triggerBtn = downloadSelector.querySelector(".download-selector__trigger");

    triggerBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      downloadSelector.classList.toggle("download-selector--active");
      const icon = triggerBtn.querySelector(".download-selector__trigger-icon");
      icon.style.transform = downloadSelector.classList.contains("download-selector--active") ? "rotate(180deg)" : "rotate(0deg)";
    });

    document.addEventListener("click", () => {
      downloadSelector.classList.remove("download-selector--active");
      const icon = triggerBtn.querySelector(".download-selector__trigger-icon");
      if (icon) icon.style.transform = "rotate(0deg)";
    });

    // ================= DATA =================
    const tableData = <%- safeJson(jsonData || []) %>;

    // ================= DELETE LOGIC =================
    let deleteId = null;
    function openDeleteModal(id) {
      deleteId = id;
      document.getElementById("deleteBindingModal").classList.add("logout-modal--active");
    }
    function closeDeleteModal() {
      document.getElementById("deleteBindingModal").classList.remove("logout-modal--active");
      deleteId = null;
    }
    async function confirmDelete() {
      if(!deleteId) return;
      const form = document.getElementById("deleteBindingForm");
      form.action = `/fairdesk/stock/ttr/delete/${deleteId}?_method=DELETE`;
      form.submit();
    }

    // ================= TABULATOR =================
    const table = new Tabulator("#master-table", {
      data: tableData,
      height: "100%",
      // layout: "fitColumns",
      responsiveLayout: false,
      movableColumns: true,
      initialSort: [{ column: "productId", dir: "asc" }],
      columns: [
        { title: "Product ID", field: "productId", minWidth: 120, widthGrow: 2, headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Type", field: "type", width: 100, headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Quality", field: "quality", width: 120, headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Color", field: "color", width: 100, headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Width", field: "width", width: 80, headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Mtrs", field: "metersPerRoll", width: 80, headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Core", field: "coreDia", width: 80, headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Ink", field: "inkFace", width: 80, headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Price/sqm", field: "purchasePricePerSqm", width: 120, headerFilter: "input", headerFilterPlaceholder: "Search" },
        {
          title: "Actions",
          width: 80,
          hozAlign: "center",
          headerSort: false,
          formatter: (cell) => {
            const id = cell.getRow().getData()._id;
            return `
              <div style="display:flex;gap:8px;">
                <button onclick="openDeleteModal('${id}')" style="border:none;background:transparent;color:#dc2626;cursor:pointer;" title="Delete">
                  <i class="fa-solid fa-trash-can"></i>
                </button>
              </div>
            `;
          }
        }
      ]
    });

    // ================= DOWNLOAD =================
    document.getElementById("download-pdf").addEventListener("click", () => {
      table.download("pdf", "ttr-details.pdf", {
        orientation: "landscape",
        title: "TTR Details",
      });
    });

    document.getElementById("download-xlsx").addEventListener("click", () => {
      table.download("xlsx", "ttr-details.xlsx", {
        sheetName: "TTR",
      });
    });
  </script>
