<% layout('/layout/boilerplate') %>

<div class="contain" style="flex-direction: column; align-items: center; justify-content: center; height: 80vh; text-align: center; gap: 20px;">
    <div style="background: white; padding: 40px 60px; border-radius: 20px; box-shadow: 0 10px 30px rgba(4, 74, 120, 0.1); border: 1px solid rgba(4, 74, 120, 0.05);">
        <div style="width: 100px; height: 100px; background: #f0f7ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; overflow: hidden; box-shadow: 0 4px 15px rgba(4, 74, 120, 0.15); border: 2px solid #ffffff;">
            <% if (authUser?.empPhoto) { %>
                <img src="/images/thumb/empimg/<%= authUser.empPhoto %>" alt="Profile" style="width: 100%; height: 100%; object-fit: cover;">
            <% } else { %>
                <span style="color: #044a78; font-weight: 800; font-size: 42px;">
                  <%= authUser?.username ? authUser.username.charAt(0).toUpperCase() : 'U' %>
                </span>
            <% } %>
        </div>
        
        <h1 style="color: #03365a; font-weight: 800; font-size: 2.5rem; margin-bottom: 8px;">Welcome, <%= authUser?.username %>!</h1>
        <p style="color: #64748b; font-size: 1.1rem; max-width: 400px; margin: 0 auto 32px;">We're glad to see you back. Use the sidebar to navigate through your Fairtech dashboard.</p>
        
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;">
            <div style="background: #f8fafc; padding: 16px; border-radius: 12px; border: 1.5px solid #f1f5f9;">
                <span style="display: block; font-size: 12px; color: #94a3b8; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 4px;">Role</span>
                <span style="font-weight: 700; color: #044a78;"><%= authUser?.role.toUpperCase() %></span>
            </div>
            <div style="background: #f8fafc; padding: 16px; border-radius: 12px; border: 1.5px solid #f1f5f9;">
                <span style="display: block; font-size: 12px; color: #94a3b8; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 4px;">Today</span>
                <span style="font-weight: 700; color: #044a78;"><%= new Date().toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></span>
            </div>
        </div>
    </div>
</div>

<style>
    @keyframes wave {
        0%, 100% { transform: rotate(0deg); }
        25% { transform: rotate(-15deg); }
        75% { transform: rotate(15deg); }
    }
</style>
