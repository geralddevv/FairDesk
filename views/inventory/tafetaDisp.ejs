<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />
<link href="https://unpkg.com/tabulator-tables@5.6.2/dist/css/tabulator_modern.min.css" rel="stylesheet">
</head>

<body>
  <div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
    <div class="indi-head">
      <h1>Tafeta</h1>
      <div class="download-btns">
        <div class="download-selector" id="downloadSelector">
          <button class="download-selector__trigger">
            <span>
              <i class="fa-solid fa-file-arrow-down"></i>
              <span class="download-typo">Download</span>
            </span>
            <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
          </button>
          <div class="download-selector__menu" id="downloads">
            <span class="download-selector__option" id="download-pdf">
              <i class="fas fa-file-pdf download-selector__option-icon"></i>
              <span>PDF</span>
            </span>
            <span class="download-selector__option" id="download-xlsx">
              <i class="fas fa-file-excel download-selector__option-icon"></i>
              <span>Excel</span>
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="table-spinner"><div class="spinner-circle"></div></div>
    <div id="master-table" class="tabulator tabulator-modern"></div>
  </div>

  <!-- Tabulator JS -->
  <script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>

  <script id="table-data" type="application/json"><%- JSON.stringify(jsonData || []) %></script>
  <script>
    const rawData = JSON.parse(document.getElementById('table-data').textContent);

    // Flatten nested fields so Tabulator headerFilter works correctly
    const tableData = rawData.map(row => ({
      ...row,
      _userName: row.userId?.userName || "",
      _userContact: row.userId?.userContact || "",
      _userLocation: row.userId?.hoLocation || "",
      _clientName: row.userId?.clientName || "",
      _tafetaProductId: row.tafetaId?.tafetaProductId || "",
      _tafetaMaterialCode: row.tafetaId?.tafetaMaterialCode || "",
      _tafetaMaterialType: row.tafetaId?.tafetaMaterialType || "",
      _tafetaColor: row.tafetaId?.tafetaColor || "",
      _tafetaGsm: row.tafetaId?.tafetaGsm || "",
      _tafetaWidth: row.tafetaId?.tafetaWidth || "",
      _tafetaMtrs: row.tafetaId?.tafetaMtrs || "",
      _tafetaCoreLen: row.tafetaId?.tafetaCoreLen || "",
      _tafetaNotch: row.tafetaId?.tafetaNotch || "",
      _tafetaCoreId: row.tafetaId?.tafetaCoreId || "",
      _tafetaMasterId: row.tafetaId?._id || "",
    }));

    const table = new Tabulator("#master-table", {
      data: tableData,
      layout: "fitDataTable",
      responsiveLayout: false,
      pagination: "local",
      paginationSize: 30,
      movableColumns: true,
      placeholder: "No data to display",
      columns: [
        {
          title: "",
          formatter: function (cell) {
            const row = cell.getRow().getData();
            if (!row._tafetaMasterId) return `<span style="color:#999">N/A</span>`;
            return `
              <button 
                onclick="window.location.href='/fairdesk/tafeta/profile/${row._tafetaMasterId}'"
                style="padding:2px 10px;background:#044A78;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;">
                <i class="fa-solid fa-eye"></i>
              </button>
            `;
          }
        },
        {
          title: "",
          hozAlign: "center",
          formatter: function (cell) {
            const row = cell.getRow().getData();
            if (!row._id) return '';
            return `
              <button 
                onclick="window.location.href='/fairdesk/tafeta-binding/edit/${row._id}'"
                style="padding:2px 10px;background:#e67e22;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;"
                title="Edit Binding">
                <i class="fa-solid fa-pen-to-square"></i>
              </button>
            `;
          }
        },
        {
          title: "Status",
          field: "status",
          hozAlign: "center",
          headerFilter: "input",
          headerFilterPlaceholder: "Filter",
          formatter: function (cell) {
            const val = cell.getValue() || "ACTIVE";
            const isActive = val === "ACTIVE";
            const bg = isActive ? "#28a745" : "#dc3545";
            return `<span style="background:${bg};color:#fff;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;">${val}</span>`;
          }
        },
        {
          title: "Stock",
          field: "stock",
          hozAlign: "center",
          formatter: (cell) => {
            const row = cell.getRow().getData();
            const stock = row.stock ?? "-";
            return `<span style="font-weight:600">${stock}</span>`;
          }
        },
        {
          title: "Order",
          hozAlign: "center",
          formatter: (cell) => {
            const row = cell.getRow().getData();
            return `
              <button 
                onclick="window.location.href='/fairdesk/sales/order?type=TAFETA&client=${encodeURIComponent(row._clientName)}&user=${row.userId?._id || ""}&item=${row._id}'"
                style="padding:2px 10px;background:#044A78;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;">
                <i class="fa-solid fa-cart-plus"></i>
              </button>
            `;
          }
        },
        { title: "Product ID", field: "_tafetaProductId", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Material Code", field: "_tafetaMaterialCode", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Material Type", field: "_tafetaMaterialType", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Color", field: "_tafetaColor", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "GSM", field: "_tafetaGsm", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Width", field: "_tafetaWidth", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Mtrs", field: "_tafetaMtrs", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Core Length", field: "_tafetaCoreLen", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Notch", field: "_tafetaNotch", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Core ID", field: "_tafetaCoreId", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Client Material Code", field: "tafetaClientMaterialCode", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Client GSM", field: "clientTafetaGsm", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Mtrs Del", field: "tafetaMtrsDel", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Rate Per Roll", field: "tafetaRatePerRoll" },
        { title: "Sale Cost", field: "tafetaSaleCost" },
        { title: "Min Qty", field: "tafetaMinQty" },
        { title: "Order Qty", field: "tafetaOdrQty" },
        { title: "Order Freq", field: "tafetaOdrFreq" },
        { title: "Credit Term", field: "tafetaCreditTerm" },
        { title: "User Name", field: "_userName", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "User Contact", field: "_userContact", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Location", field: "_userLocation", headerFilter: "input", headerFilterPlaceholder: "Search" },
      ],
    });

    const selector = document.getElementById("downloadSelector");
    const trigger = selector.querySelector(".download-selector__trigger");

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      selector.classList.toggle("download-selector--active");
    });

    document.addEventListener("click", () => {
      selector.classList.remove("download-selector--active");
    });

    document.getElementById("download-pdf").addEventListener("click", () => {
      table.download("pdf", "tafeta.pdf", {
        orientation: "landscape",
        title: "Tafeta Data",
      });
      selector.classList.remove("download-selector--active");
    });

    document.getElementById("download-xlsx").addEventListener("click", () => {
      table.download("xlsx", "tafeta.xlsx", {
        sheetName: "Tafeta",
      });
      selector.classList.remove("download-selector--active");
    });
  </script>
</body>
