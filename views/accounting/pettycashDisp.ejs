<% layout('/layout/boilerplate') -%>

<!-- ================= TABULATOR CSS ================= -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
  <div class="indi-head">
    <span style="display: flex; align-items: center; gap: 10px">
      <button
        id="backToSnapshot"
        style="
          display: none;
          background-color: transparent;
          padding: 2px 14px;
          border: 1px solid #ffffffaa;
          border-radius: 0.3rem;
          cursor: pointer;
        "
      >
        <i class="fa-solid fa-arrow-left" style="color: #fff"></i>
      </button>
      <h1>Petty Cash</h1>
    </span>

    <div class="download-selector" id="downloadSelector">
      <div class="download-selector__trigger">
        <span><i class="fa-solid fa-file-arrow-down"></i> Download</span>
        <i class="fa-solid fa-chevron-down"></i>
      </div>

      <div class="download-selector__menu">
        <div class="download-selector__option" id="download-pdf">PDF</div>
        <div class="download-selector__option" id="download-xlsx">Excel</div>
      </div>
    </div>
  </div>

  <div class="table-spinner"><div class="spinner-circle"></div></div>
  <div id="master-table"></div>
</div>

<!-- ===== EDIT LOG DIALOG ===== -->
<div
  id="pc-edit-dialog"
  style="display:none; position:fixed; inset:0; background:rgba(17,24,39,0.55); z-index:9999; align-items:center; justify-content:center; backdrop-filter: blur(1px);"
>
  <div style="background:#fff; width:560px; max-width:94vw; border-radius:14px; padding:20px 22px; box-shadow:0 20px 60px rgba(0,0,0,0.25);">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
      <h3 style="margin:0; color:#0f172a; font-size:18px;">
        <i class="fa-solid fa-pen-to-square" style="margin-right:6px; color:#2563eb;"></i>Edit Petty Cash Log
      </h3>
      <button type="button" onclick="closeEditDialog()" title="Close" style="border:none; background:transparent; color:#6b7280; font-size:18px; cursor:pointer;">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <div style="font-size:12px; color:#64748b; margin-bottom:12px;">Update the amount and details. Balances will auto-recalculate.</div>
    <input type="hidden" id="pc-edit-id" />

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px;">
      <div>
        <label style="font-size:12px; color:#6b7280; font-weight:600;">Type</label>
        <select id="pc-edit-type" style="width:100%; height:42px; padding:10px 12px; border:1px solid #cbd5e1; border-radius:8px; background:#ffffff; color:#0f172a; font-size:14px; line-height:20px;">
          <option value="RECEIVED">RECEIVED</option>
          <option value="PAID">PAID</option>
        </select>
      </div>
      <div>
        <label style="font-size:12px; color:#6b7280; font-weight:600;">Amount</label>
        <div style="display:flex; align-items:center; gap:8px; border:1px solid #cbd5e1; border-radius:8px; padding:0 10px; background:#ffffff; height:42px;">
          <span style="color:#044A78; font-weight:600;">₹</span>
          <input type="number" id="pc-edit-amount" min="1" style="width:100%; padding:10px 0; border:none; background:transparent; outline:none; color:#0f172a; font-size:14px; line-height:20px;" />
        </div>
      </div>
    </div>

    <div id="pc-edit-from-wrap" style="margin-bottom:12px;">
      <label style="font-size:12px; color:#6b7280; font-weight:600;">From</label>
      <input type="text" id="pc-edit-from" placeholder="Sender / source" style="width:100%; height:42px; padding:10px 12px; border:1px solid #cbd5e1; border-radius:8px; background:#ffffff; color:#0f172a; font-size:14px; line-height:20px;" />
    </div>
    <div id="pc-edit-to-wrap" style="margin-bottom:12px;">
      <label style="font-size:12px; color:#6b7280; font-weight:600;">To</label>
      <input type="text" id="pc-edit-to" placeholder="Receiver / payee" style="width:100%; height:42px; padding:10px 12px; border:1px solid #cbd5e1; border-radius:8px; background:#ffffff; color:#0f172a; font-size:14px; line-height:20px;" />
    </div>
    <div style="margin-bottom:14px;">
      <label style="font-size:12px; color:#6b7280; font-weight:600;">Reason</label>
      <input type="text" id="pc-edit-reason" placeholder="Optional note" style="width:100%; height:42px; padding:10px 12px; border:1px solid #cbd5e1; border-radius:8px; background:#ffffff; color:#0f172a; font-size:14px; line-height:20px;" />
    </div>

    <div style="display:flex; justify-content:flex-end; gap:10px;">
      <button type="button" onclick="closeEditDialog()" style="padding:9px 16px; border:1px solid #e2e8f0; background:white; color:#334155; border-radius:8px; cursor:pointer;">Cancel</button>
      <button type="button" onclick="submitEditLog()" style="padding:9px 16px; border:none; background:#044A78; color:white; border-radius:8px; cursor:pointer;">Save Changes</button>
    </div>
  </div>
</div>

<!-- ===== DELETE LOG DIALOG ===== -->
<div
  id="pc-delete-dialog"
  style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;"
>
  <div style="background:#fff; width:460px; max-width:92vw; border-radius:10px; padding:18px 20px;">
    <h3 style="margin:0 0 10px; color:#b91c1c; font-size:17px;">
      <i class="fa-solid fa-triangle-exclamation" style="margin-right:6px;"></i>Delete Log
    </h3>
    <p style="margin:0 0 14px; color:#374151;">Are you sure you want to delete this petty cash log?</p>
    <input type="hidden" id="pc-delete-id" />
    <div style="display:flex; justify-content:flex-end; gap:10px;">
      <button type="button" onclick="closeDeleteDialog()" style="padding:8px 16px; border:1px solid #d1d5db; background:white; color:#374151; border-radius:6px; cursor:pointer;">Cancel</button>
      <button type="button" onclick="submitDeleteLog()" style="padding:8px 16px; border:none; background:#ef4444; color:white; border-radius:6px; cursor:pointer;">Yes, Delete</button>
    </div>
  </div>
</div>

<!-- ================= SCRIPTS ================= -->
<script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.4.0/jspdf.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>

<script>
  const tableData = <%- JSON.stringify(jsonData) %>;
  const snapshotData = [...tableData];
  let currentLocation = null;

  function formatDateTime(value) {
      if (!value) return "-";

      const d = new Date(value);
      return d.toLocaleString("en-IN", {
        day: "2-digit",
        month: "short",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit",
        hour12: true,
      });
    }


  /* ===== SNAPSHOT COLUMNS (LIKE LOAN) ===== */
  const baseColumns = [
    { title: "Location", field: "location", headerSort: false },
    {
      title: "Current Balance",
      field: "balance",
      formatter: c => `₹ ${c.getValue()}`
    },
    { title: "Status", field: "status" },
    {
      title: "Last Updated",
      field: "updatedAt",
      formatter: cell => formatDateTime(cell.getValue()),
    },
    {
      title: "Action",
      formatter: () =>
        `<span style="text-decoration:underline;font-weight:600;cursor:pointer">
          View Transactions
         </span>`,
      cellClick: async (e, cell) => {
        const { location } = cell.getRow().getData();
        currentLocation = location;

        const res = await fetch(`/fairdesk/pettycash/logs/${location}`);
        const { history } = await res.json();

        table.setColumns(logColumns);
        table.replaceData(history);

        document.querySelector(".indi-head h1").innerText =
          `Petty Cash — ${location}`;
        document.getElementById("backToSnapshot").style.display = "inline-flex";
      }
    },
  ];

  /* ===== LOG COLUMNS ===== */
  const logColumns = [
    { title: "From", field: "from" },
    { title: "To", field: "to" },
    { title: "Opening Balance", field: "openingBalance" },
    {
      title: "Amount",
      field: "amount",
      formatter: c => {
        const r = c.getRow().getData();
        return r.type === "OUTWARD"
          ? `- ₹${c.getValue()}`
          : `+ ₹${c.getValue()}`;
      },
    },
    { title: "Closing Balance", field: "closingBalance" },
    { title: "Type", field: "type" },
    { title: "Reason", field: "reason" },
    {
      title: "Date",
      field: "createdAt",
      formatter: cell => formatDateTime(cell.getValue()),
    },
    {
      title: "Actions",
      width: 80,
      hozAlign: "center",
      headerHozAlign: "center",
      headerSort: false,
      formatter: () =>
        `<button class="pc-log-btn pc-log-edit" title="Edit" style="height:20px; width:28px; padding:0; margin-right:6px; border:1px solid #d1d5db; background:#fff; border-radius:4px; cursor:pointer; line-height:1;">
            <i class="fa-solid fa-pen-to-square" style="font-size:11px; color:#044A78;"></i>
         </button>
         <button class="pc-log-btn pc-log-delete" title="Delete" style="height:20px; width:28px; padding:0; border:1px solid #fca5a5; background:#fee2e2; border-radius:4px; cursor:pointer; line-height:1;">
            <i class="fa-solid fa-trash" style="font-size:11px; color:#b91c1c;"></i>
         </button>`,
      cellClick: (e, cell) => {
        const row = cell.getRow().getData();
        if (e.target.closest(".pc-log-edit")) {
          openEditDialog(row);
        } else if (e.target.closest(".pc-log-delete")) {
          openDeleteDialog(row);
        }
      },
    },
  ];

  const table = new Tabulator("#master-table", {
    data: tableData,
    layout: "fitColumns",
    pagination: "local",
    paginationSize: 30,
    columns: baseColumns,
  });

  /* ===== BACK ===== */
  document.getElementById("backToSnapshot").addEventListener("click", () => {
    table.setColumns(baseColumns);
    table.replaceData(snapshotData);
    document.querySelector(".indi-head h1").innerText = "Petty Cash";
    document.getElementById("backToSnapshot").style.display = "none";
    currentLocation = null;
  });

  /* ===== DOWNLOAD ===== */
  const selector = document.getElementById("downloadSelector");
  selector.querySelector(".download-selector__trigger").onclick = () =>
    selector.classList.toggle("download-selector--active");

  document.getElementById("download-pdf").onclick = () =>
    table.download("pdf", "pettycash.pdf");

  document.getElementById("download-xlsx").onclick = () =>
    table.download("xlsx", "pettycash.xlsx");
</script>

<script>
  const editDialog = document.getElementById("pc-edit-dialog");
  const deleteDialog = document.getElementById("pc-delete-dialog");

  function syncEditFields() {
    const type = document.getElementById("pc-edit-type").value;
    const fromWrap = document.getElementById("pc-edit-from-wrap");
    const toWrap = document.getElementById("pc-edit-to-wrap");

    if (type === "PAID") {
      fromWrap.style.display = "none";
      toWrap.style.display = "block";
    } else {
      toWrap.style.display = "none";
      fromWrap.style.display = "block";
    }
  }

  document.getElementById("pc-edit-type").addEventListener("change", syncEditFields);

  function openEditDialog(row) {
    document.getElementById("pc-edit-id").value = row._id;
    document.getElementById("pc-edit-amount").value = row.amount;
    document.getElementById("pc-edit-reason").value = row.reason || "";
    document.getElementById("pc-edit-type").value = row.type === "INWARD" ? "RECEIVED" : "PAID";
    document.getElementById("pc-edit-from").value = row.from || "";
    document.getElementById("pc-edit-to").value = row.to || "";
    syncEditFields();
    editDialog.style.display = "flex";
  }

  function closeEditDialog() {
    editDialog.style.display = "none";
  }

  function openDeleteDialog(row) {
    document.getElementById("pc-delete-id").value = row._id;
    deleteDialog.style.display = "flex";
  }

  function closeDeleteDialog() {
    deleteDialog.style.display = "none";
  }

  function updateSnapshotBalance(location, balance) {
    const idx = snapshotData.findIndex((s) => s.location === location);
    if (idx !== -1) {
      snapshotData[idx].balance = balance;
      snapshotData[idx].status = balance > 0 ? "ACTIVE" : "EMPTY";
      snapshotData[idx].updatedAt = new Date().toISOString();
    }
  }

  async function refreshLogs() {
    if (!currentLocation) return;
    const res = await fetch(`/fairdesk/pettycash/logs/${currentLocation}`);
    const { history } = await res.json();
    table.replaceData(history);
  }

  async function submitEditLog() {
    const id = document.getElementById("pc-edit-id").value;
    const typeUi = document.getElementById("pc-edit-type").value;
    const amount = Number(document.getElementById("pc-edit-amount").value);
    const from = document.getElementById("pc-edit-from").value.trim();
    const to = document.getElementById("pc-edit-to").value.trim();
    const reason = document.getElementById("pc-edit-reason").value.trim();

    if (!id || !amount || amount <= 0) {
      alert("Please enter a valid amount.");
      return;
    }

    if (typeUi === "RECEIVED" && !from) {
      alert("From is required.");
      return;
    }

    if (typeUi === "PAID" && !to) {
      alert("To is required.");
      return;
    }

    const payload = {
      amount,
      type: typeUi === "RECEIVED" ? "INWARD" : "OUTWARD",
      from,
      to,
      reason,
    };

    try {
      const res = await fetch(`/fairdesk/pettycash/logs/${id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok) {
        alert(data.message || "Failed to update log");
        return;
      }

      updateSnapshotBalance(currentLocation, data.balance);
      await refreshLogs();
    } catch (err) {
      console.error(err);
      alert("Failed to update log");
    }

    closeEditDialog();
  }

  async function submitDeleteLog() {
    const id = document.getElementById("pc-delete-id").value;
    if (!id) return;

    try {
      const res = await fetch(`/fairdesk/pettycash/logs/${id}`, { method: "DELETE" });
      const data = await res.json();
      if (!res.ok) {
        alert(data.message || "Failed to delete log");
        return;
      }

      updateSnapshotBalance(currentLocation, data.balance);
      await refreshLogs();
    } catch (err) {
      console.error(err);
      alert("Failed to delete log");
    }

    closeDeleteDialog();
  }
</script>

<script>
  /* ===== TRANSACTION TYPE → VISIBILITY + VALUE FIX ===== */
  function syncFields() {
    if (txnType.value === "PAID") {
      // PAID → only TO
      fromWrap.style.display = "none";
      fromInput.required = false;
      fromInput.value = "-"; // ✅ FIXED

      toWrap.style.display = "block";
      toInput.required = true;
    } else {
      // RECEIVED → only FROM
      toWrap.style.display = "none";
      toInput.required = false;
      toInput.value = "-"; // ✅ FIXED

      fromWrap.style.display = "block";
      fromInput.required = true;
    }
  }

  txnType.addEventListener("change", syncFields);
  syncFields(); // run once on load
</script>

