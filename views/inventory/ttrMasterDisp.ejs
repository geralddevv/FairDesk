<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />
<link href="https://unpkg.com/tabulator-tables@5.6.2/dist/css/tabulator_modern.min.css" rel="stylesheet" />

<body>
  <div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
    <style>
      .header-action-btn {
        background-color: #f0f0f0;
        color: #044a78;
        padding: 2px 14px; /* Matches Download button padding exactly */
        font-size: 14px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        border-radius: 0.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: all 0.2s ease-in-out;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .header-action-btn:hover {
        background-color: #e4e4e4;
      }
    </style>

    <div class="indi-head">
      <h1>TTR Master</h1>
      <div style="display: flex; gap: 10px; align-items: center">
        <button class="header-action-btn" onclick="window.location.href = '/fairdesk/form/ttr'">
          <i class="fa-solid fa-plus" style="margin-right: 4px"></i> TTR
        </button>
        <button class="header-action-btn" onclick="window.location.href = '/fairdesk/form/ttr-vendor-binding'">
          <i class="fa-solid fa-plus" style="margin-right: 4px"></i> Vendor Binding
        </button>

        <div class="download-selector" id="downloadSelector">
          <button class="download-selector__trigger">
            <span>
              <i class="fa-solid fa-file-arrow-down"></i>
              <span class="download-typo">Download</span>
            </span>
            <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
          </button>
          <div class="download-selector__menu" id="downloads">
            <span class="download-selector__option" id="download-pdf">
              <i class="fas fa-file-pdf download-selector__option-icon"></i>
              <span>PDF</span>
            </span>
            <span class="download-selector__option" id="download-xlsx">
              <i class="fas fa-file-excel download-selector__option-icon"></i>
              <span>Excel</span>
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="table-spinner"><div class="spinner-circle"></div></div>
    <div id="master-table" class="tabulator tabulator-modern"></div>
  </div>

  <!-- Tabulator JS -->
  <script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>

  <script>
    // Parse data from Express
    const tableData = <%- JSON.stringify(jsonData) %>;
    const stockLocations = <%- JSON.stringify(stockLocations || []) %>;

    // Initialize Tabulator
    const baseColumns = [
      {
        title: "",
        formatter: function (cell) {
          const row = cell.getRow().getData();
          if (!row._id) return "";
          return `
            <button
              onclick="window.location.href='/fairdesk/ttr/profile/${row._id}'"
              style="padding:2px 10px;background:#044A78;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;">
              <i class="fa-solid fa-eye"></i>
            </button>
          `;
        }
      },
      {
        title: "Product ID",
        field: "ttrProductId",
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
      },
      {
        title: "Material Code",
        field: "ttrMaterialCode",
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
      },
      {
        title: "Type",
        field: "ttrType",
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
      },
      {
        title: "Color",
        field: "ttrColor",
        headerFilter: "select",
        headerFilterParams: {
          values: {
            "": "All",
            BLACK: "BLACK",
            RED: "RED",
            GREEN: "GREEN",
            BLUE: "BLUE",
            YELLOW: "YELLOW",
            GOLD: "GOLD",
            SILVER: "SILVER",
          },
          clearable: true,
        },
      },
      { title: "Width", field: "ttrWidth" },
      { title: "Mtrs", field: "ttrMtrs" },
      { title: "Ink Face", field: "ttrInkFace" },
      {
        title: "Core ID",
        field: "ttrCoreId",
        headerFilter: "select",
        headerFilterParams: {
          values: { "": "All", 0.5: "0.5", 1: "1" },
          clearable: true,
        },
      },
      { title: "Core Len", field: "ttrCoreLength" },
      {
        title: "Notch",
        field: "ttrNotch",
        headerFilter: "select",
        headerFilterParams: {
          values: { "": "All", NO: "NO", YES: "YES" },
          clearable: true,
        },
      },
      { title: "Winding", field: "ttrWinding" },
    ];

    const stockColumns = stockLocations.map((loc) => ({
      title: loc,
      field: `stock_${String(loc).replace(/[^A-Za-z0-9]+/g, "_")}`,
      hozAlign: "right",
      headerHozAlign: "center",
      width: 110,
      formatter: (cell) => {
        const v = Number(cell.getValue() || 0);
        return v === 0 ? "" : String(v);
      },
    }));

    const table = new Tabulator("#master-table", {
      data: tableData,
      layout: "fitDataStretch", // Good for wide tables
      responsiveLayout: false,
      pagination: "local",
      paginationSize: 30,
      movableColumns: true,
      placeholder: "No data to display",
      columns: [...baseColumns, ...stockColumns],
    });

    // Dropdown toggle
    const selector = document.getElementById("downloadSelector");
    const trigger = selector.querySelector(".download-selector__trigger");

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      selector.classList.toggle("download-selector--active");
    });

    document.addEventListener("click", () => {
      selector.classList.remove("download-selector--active");
    });

    // PDF download
    document.getElementById("download-pdf").addEventListener("click", () => {
      table.download("pdf", "ttr-master.pdf", {
        orientation: "landscape",
        title: "TTR Master Data",
      });
      selector.classList.remove("download-selector--active");
    });

    // Excel download
    document.getElementById("download-xlsx").addEventListener("click", () => {
      table.download("xlsx", "ttr-master.xlsx", {
        sheetName: "TTR Master",
      });
      selector.classList.remove("download-selector--active");
    });
  </script>
</body>
