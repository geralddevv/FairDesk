<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<style>
  .tape-details-shell {
    padding: 18px;
    background: linear-gradient(180deg, #eef5fb 0%, #f7f9fc 100%);
  }

  .tape-details-card {
    position: relative;
    background: #fff;
    border-radius: 18px;
    box-shadow: 0 18px 42px rgba(4, 74, 120, 0.12);
    border: 1px solid rgba(4, 74, 120, 0.12);
    overflow: hidden;
  }

  .tape-details-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-end;
    padding: 24px 24px 22px;
    background:
      radial-gradient(circle at top right, rgba(255,255,255,0.16), transparent 34%),
      linear-gradient(135deg, #044a78 0%, #03365a 100%);
    color: #fff;
  }

  .header-copy {
    max-width: 100%;
  }

  .tape-details-header h1 {
    margin: 0;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: 0.2px;
  }

  .header-actions {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .header-action-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.2px;
    backdrop-filter: blur(8px);
    transition: background 0.18s ease;
  }

  .header-action-link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.2);
  }

  .section-title {
    margin: 0 0 14px;
    color: #044a78;
    font-size: 17px;
    font-weight: 700;
  }

  .diff-table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid #e6eaf2;
    border-radius: 12px;
    overflow: hidden;
  }

  .diff-table th,
  .diff-table td {
    padding: 10px 12px;
    border-bottom: 1px solid #e6eaf2;
    text-align: left;
    font-size: 13px;
    vertical-align: top;
  }

  .diff-table th {
    background: #f4f7ff;
    color: #044a78;
    font-weight: 700;
  }

  .diff-table tbody tr:last-child td {
    border-bottom: none;
  }

  .diff-table .key-col {
    width: 32%;
    color: #5a6586;
    font-weight: 600;
  }

  .diff-table .resolved {
    font-weight: 700;
    color: #1f2a44;
  }

  .tape-details-body {
    padding: 22px 24px 24px;
  }

  @media (max-width: 768px) {
    .tape-details-header {
      flex-direction: column;
      align-items: flex-start;
      padding-top: 24px;
    }
  }
</style>

<div class="main-content tape-details-shell">
  <div class="tape-details-card">
    <div class="tape-details-header">
      <div class="header-copy">
        <h1><%= pageTitle %></h1>
      </div>
      <div class="header-actions">
        <% if (editUrl) { %>
          <a class="header-action-link" href="<%= editUrl %>">
            <i class="fa-solid fa-pencil"></i>
            <%= editLabel %>
          </a>
        <% } %>
      </div>
    </div>

    <div class="tape-details-body">
      <div class="details-section">
        <h3 class="section-title"><%= sectionTitle %></h3>
        <table class="diff-table">
          <thead>
            <tr>
              <th class="key-col">Field</th>
              <th><%= valueHeader %></th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach(row => { %>
              <tr>
                <td class="key-col"><%= row.label %></td>
                <td class="resolved"><%= row.value %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
