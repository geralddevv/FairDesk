<% layout('/layout/boilerplate') -%>

<div class="main-content">
  <form action="<%= typeof confirmMode !== 'undefined' && confirmMode ? '/fairdesk/sales/order/status' : '/fairdesk/sales/order' %>" method="post" class="needs-validation" autocomplete="off" novalidate>
    <input type="hidden" name="orderId" value="<%= typeof orderToEdit !== 'undefined' && orderToEdit ? orderToEdit._id : '' %>" />
    <input type="hidden" name="submissionToken" value="<%= typeof submissionToken !== 'undefined' && submissionToken ? submissionToken : '' %>" />
    <% if (typeof confirmMode !== 'undefined' && confirmMode) { %>
      <input type="hidden" name="status" value="CONFIRMED" />
    <% } %>
    <div class="span-full form-heading">
      <h1><%= typeof confirmMode !== 'undefined' && confirmMode ? 'Dispatch Order' : (typeof orderToEdit !== 'undefined' && orderToEdit ? 'Edit Sales Order' : 'Sales Order') %></h1>
    </div>

    <!-- Stock Status Bar with Location Selection -->
    <div id="stock-display" class="span-full" style="display: none; padding: 10px 15px; background: #fff; border: 1px solid #044A78; border-radius: 0.5rem; transition: all 0.3s ease;">
      <!-- Content populated by JS -->
    </div>
    <input type="hidden" name="sourceLocation" id="source-location" />

    <!-- ================= ORDER TYPE ================= -->
    <div class="span-full form-subheading">
      <h1>Order Details</h1>
    </div>

    <div class="span-seven">
      <label for="item-type">Item Type</label>
      <select name="itemType" id="item-type" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Select Item Type</option>
        <option value="TAPE">Tape</option>
        <option value="POS_ROLL">POS Roll</option>
        <option value="TAFETA">Tafeta</option>
        <option value="LABEL">Label</option>
        <option value="TTR">TTR</option>
      </select>
    </div>

    <div class="span-six">
      <label for="client-name">Client Name</label>
      <select name="clientName" id="client-name" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Select Client</option>
        <% clients?.forEach(client => { %>
          <option value="<%= client %>"><%= client %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-six">
      <label for="user-name">User Name</label>
      <select name="userId" id="user-name" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Select User</option>
      </select>
      <input type="hidden" name="userName" id="user-name-hidden" />
    </div>

    <div class="span-six">
      <label for="user-location">Location</label>
      <select id="user-location" name="userLocation" class="form-control select-tag">
        <option value="" disabled selected hidden>Location</option>
      </select>
    </div>

    <div class="span-seven">
      <label for="item-select">Select Item</label>
      <select name="itemId" id="item-select" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Select Item</option>
      </select>
    </div>

    <div id="selected-item-details" class="span-full" style="padding:6px 8px;background:#fff;border:1px solid #044A78;border-radius:4px;display:none;"></div>

    <!-- ================= QUANTITY & DATE ================= -->
    <div class="span-full form-subheading">
      <h1>Order Info</h1>
    </div>

    <div class="span-five">
      <label for="quantity">Order Quantity</label>
      <input type="number" id="quantity" name="quantity" class="form-control" min="1" placeholder="Enter quantity" required />
    </div>

    <div class="span-five">
      <label for="po-number">PO Number</label>
      <input type="text" id="po-number" name="poNumber" class="form-control" placeholder="Enter PO number" required />
    </div>    

    <div class="span-four">
      <label for="item-rate">Rate</label>
      <input type="text" id="item-rate" class="form-control" placeholder="Rate" readonly />
    </div>

    <div class="span-four">
      <label for="order-rate">Curr Rate</label>
      <input type="number" id="order-rate" name="orderRate" class="form-control" placeholder="Enter current rate" step="0.01" />
    </div>

    <div class="span-six">
      <label for="estimated-date">Est Delivery Date</label>
      <input type="date" id="estimated-date" name="estimatedDate" class="form-control" required />
    </div>

    <div class="span-half" style="grid-column: span 8;">
      <label for="remarks">Remarks (Optional)</label>
      <input type="text" id="remarks" name="remarks" class="form-control" placeholder="Any special instructions..." />
    </div>

    <!-- Stock Warning -->
    <div id="stock-warning" class="span-full" style="display: none; padding: 8px 15px; background: #fef3c7; border: 1px solid #f59e0b; border-radius: 0.5rem; color: #92400e; font-size: 14px; font-weight: 500;">
      <i class="fa-solid fa-triangle-exclamation" style="margin-right: 6px;"></i>
      <span id="stock-warning-text"></span>
    </div>

    <!-- ================= CONFIRMATION DETAILS (only in confirm mode) ================= -->
    <% if (typeof confirmMode !== 'undefined' && confirmMode) { %>
    <div id="confirmation-section" class="span-full form-subheading">
      <h1>Confirmation Details</h1>
    </div>

    <div class="span-penta">
      <label for="confirm-date">Date</label>
      <input type="date" id="confirm-date" name="confirmDate" class="form-control" required />
    </div>

    <div class="span-hexa">
      <label for="invoice-number">Invoice Number</label>
      <input type="text" id="invoice-number" name="invoiceNumber" class="form-control" placeholder="Enter invoice number" required />
    </div>

    <div class="span-penta">
      <label for="confirm-quantity">Quantity</label>
      <input type="number" id="confirm-quantity" name="confirmQuantity" class="form-control" min="1" required />
    </div>
    
    <div id="logs-wrapper" style="grid-column: 1 / -1;">
    <% if (typeof logs !== 'undefined' && logs.length > 0) { %>
      <div class="span-full" style="padding: 12px; background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 0.5rem; color: #0369a1; font-size: 14px; margin-top: 10px;">
        <% 
          let runningRemaining = orderToEdit.quantity - orderToEdit.dispatchedQuantity;
        %>
        
        <div style="display: flex; align-items: center; margin-bottom: 8px; padding-bottom: 8px; border-bottom: 1px solid #e0f2fe;">
            <span><strong>Partial Dispatch:</strong> <%= orderToEdit.dispatchedQuantity %> sent / <%= orderToEdit.quantity - orderToEdit.dispatchedQuantity %> remaining</span>
        </div>

        <div class="logs-scroll" style="max-height: 120px; overflow-y: auto; padding-right: 5px; width: 100%;">
            <% logs.forEach((log, index) => { %>
            <div style="padding: 6px 0; border-bottom: 1px dashed #e0f2fe; font-size: 13px; display: flex; justify-content: space-between; align-items: center;">
                <span>
                    <span style="color: #64748b; font-size: 12px; margin-right: 5px;">
                        <%= new Date(log.performedAt).toLocaleDateString('en-IN', { month: 'short', day: '2-digit', year: 'numeric' }) %>
                    </span>
                    <% if (log.invoiceNumber) { %>
                    <span style="font-family: monospace; background: #e0f2fe; padding: 1px 6px; border-radius: 4px; font-size: 12px;">
                        <%= log.invoiceNumber %>
                    </span>
                    <% } %>
                <span style="margin-left: 6px;"><strong><%= log.quantity %></strong> sent</span>
                <span style="color: #64748b;">(Remaining: <%= runningRemaining %>)</span>
                </span>
                <span style="display: flex; gap: 6px; align-items: center; flex-shrink: 0;">
                    <button type="button" data-log-id="<%= log._id %>" data-log-qty="<%= log.quantity %>" data-log-invoice="<%= log.invoiceNumber || '' %>" data-log-date="<%= new Date(log.performedAt).toISOString().split('T')[0] %>"
                        onclick="openEditDialog(this.getAttribute('data-log-id'), parseInt(this.getAttribute('data-log-qty')), this.getAttribute('data-log-invoice'), this.getAttribute('data-log-date'))"
                        style="background: none; border: none; color: #3b82f6; cursor: pointer; padding: 2px 4px; font-size: 13px; border-radius: 4px; transition: background 0.2s;"
                        onmouseover="this.style.background='#e0f2fe'" onmouseout="this.style.background='none'"
                        title="Edit Log">
                        <i class="fa-solid fa-pencil"></i>
                    </button>
                    <button type="button" onclick="confirmDeleteLog('<%= log._id %>')"
                        style="background: none; border: none; color: #ef4444; cursor: pointer; padding: 2px 4px; font-size: 13px; border-radius: 4px; transition: background 0.2s;"
                        onmouseover="this.style.background='#fee2e2'" onmouseout="this.style.background='none'"
                        title="Delete Log">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>
                </span>
                
                <% 
                // For the next iteration (older log), the remaining amount was higher by this dispatched amount
                runningRemaining += log.quantity; 
                %>
            </div>
            <% }) %>
        </div>
      </div>
      
      <style>
        .logs-scroll::-webkit-scrollbar {
          width: 4px;
        }
        .logs-scroll::-webkit-scrollbar-track {
          background: transparent;
        }
        .logs-scroll::-webkit-scrollbar-thumb {
          background-color: rgba(26, 26, 46, 0.5);
          border-radius: 6px;
        }
        .logs-scroll::-webkit-scrollbar-thumb:hover {
          background-color: rgba(26, 26, 46, 0.75);
        }
      </style>
    <% } else if (typeof orderToEdit !== 'undefined' && orderToEdit && orderToEdit.dispatchedQuantity > 0) { %>
      <div class="span-full" style="padding: 10px; background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 0.5rem; color: #0369a1; font-size: 14px; margin-top: 10px;">
        <i class="fa-solid fa-circle-info" style="margin-right: 5px;"></i>
        <strong>Partial Dispatch:</strong> <%= orderToEdit.dispatchedQuantity %> sent. Remaining: <%= orderToEdit.quantity - orderToEdit.dispatchedQuantity %>
      </div>
    <% } %>
    </div>
    <% } %>

<!-- ================= EDIT LOG DIALOG ================= -->
<div id="edit-log-dialog" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center; transition:opacity 0.3s;">
  <div style="background:white; border-radius:8px; width:440px; max-width:90%; box-shadow:0 4px 15px rgba(0,0,0,0.2); overflow:hidden; animation:logDialogPopIn 0.2s ease-out;">
    <div style="padding:20px 20px 0; border-bottom: 1px solid #e5e7eb;">
      <h3 style="margin:0 0 15px; color:#044A78; font-size:17px;"><i class="fa-solid fa-pencil" style="margin-right:6px;"></i>Edit Dispatch Log</h3>
    </div>
    <div style="padding:20px;">
      <input type="hidden" id="edit-log-id" />
      <div style="margin-bottom:14px;">
        <label style="font-size:13px; font-weight:600; color:#374151; display:block; margin-bottom:4px;">Quantity <span style="color:#ef4444">*</span></label>
        <input type="number" id="edit-log-qty" min="1" style="width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; box-sizing:border-box; transition:border-color 0.2s;" />
      </div>
      <div style="margin-bottom:14px;">
        <label style="font-size:13px; font-weight:600; color:#374151; display:block; margin-bottom:4px;">Invoice Number</label>
        <input type="text" id="edit-log-invoice" style="width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; box-sizing:border-box; transition:border-color 0.2s;" />
      </div>
      <div style="margin-bottom:4px;">
        <label style="font-size:13px; font-weight:600; color:#374151; display:block; margin-bottom:4px;">Date</label>
        <input type="date" id="edit-log-date" style="width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; box-sizing:border-box; transition:border-color 0.2s;" />
      </div>
    </div>
    <div style="padding:15px 20px; background:#f9fafb; display:flex; justify-content:flex-end; gap:10px; border-top:1px solid #e5e7eb;">
      <button type="button" onclick="closeEditDialog()" style="padding:8px 16px; border:1px solid #d1d5db; background:white; color:#374151; border-radius:6px; cursor:pointer; font-weight:500; transition:all 0.2s;" onmouseover="this.style.background='#f3f4f6'" onmouseout="this.style.background='white'">Cancel</button>
      <button type="button" onclick="submitEditLog()" style="padding:8px 16px; border:none; background:#044A78; color:white; border-radius:6px; cursor:pointer; font-weight:500; transition:all 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Save Changes</button>
    </div>
  </div>
</div>

<!-- ================= DELETE LOG DIALOG ================= -->
<div id="delete-log-dialog" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center; transition:opacity 0.3s;">
  <div style="background:white; border-radius:8px; width:400px; max-width:90%; box-shadow:0 4px 15px rgba(0,0,0,0.2); overflow:hidden; animation:logDialogPopIn 0.2s ease-out;">
    <div style="padding:25px 20px; text-align:center;">
      <i class="fa-solid fa-triangle-exclamation" style="font-size:28px; color:#ef4444; margin-bottom:12px;"></i>
      <p style="margin:0; color:#333; font-size:16px; line-height:1.5;">Are you sure you want to <strong>delete</strong> this dispatch log? Stock will be reversed.</p>
      <input type="hidden" id="delete-log-id" />
    </div>
    <div style="padding:15px 20px; background:#f9fafb; display:flex; justify-content:flex-end; gap:10px; border-top:1px solid #e5e7eb;">
      <button type="button" onclick="closeDeleteDialog()" style="padding:8px 16px; border:1px solid #d1d5db; background:white; color:#374151; border-radius:6px; cursor:pointer; font-weight:500; transition:all 0.2s;" onmouseover="this.style.background='#f3f4f6'" onmouseout="this.style.background='white'">Go Back</button>
      <button type="button" onclick="submitDeleteLog()" style="padding:8px 16px; border:none; background:#ef4444; color:white; border-radius:6px; cursor:pointer; font-weight:500; transition:all 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Yes, Delete</button>
    </div>
  </div>
</div>

<style>
  @keyframes logDialogPopIn {
    0% { transform: scale(0.9); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  #edit-log-qty:focus, #edit-log-invoice:focus, #edit-log-date:focus {
    outline: none;
    border-color: #044A78;
    box-shadow: 0 0 0 2px rgba(26, 26, 46, 0.1);
  }
</style>

    <!-- ================= SUBMIT ================= -->
    <div class="span-full btn-grp">
      <button type="submit">
        <% if (typeof confirmMode !== 'undefined' && confirmMode) { %>
          <i class="fa-solid fa-check-double"></i> Dispatch Order
        <% } else { %>
          <i class="fa-solid fa-check"></i> <%= typeof orderToEdit !== 'undefined' && orderToEdit ? 'Update Order' : 'Create Order' %>
        <% } %>
      </button>
    </div>
  </form>
</div>

<style>
  .location-option {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-right: 5px;
    cursor: pointer;
    padding: 5px 8px;
    border-radius: 0.4rem;
    border: 2px solid transparent;
    transition: all 0.2s ease;
    user-select: none;
  }

  .location-option:hover {
    background: #f0f0ff;
  }

  .location-option.selected {
    border-color: #044A78;
    background: #eef0ff;
  }

  .location-radio {
    accent-color: #044A78;
    width: 16px;
    height: 16px;
    cursor: pointer;
  }

  .location-label {
    color: #044A78;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
  }

  .location-qty {
    font-weight: 700;
    color: #044A78;
    font-size: 15px;
  }
</style>

<script>
  // Inject data safely using DOM elements for valid IDE linting
  const orderDataEl = document.createElement('span');
  orderDataEl.innerHTML = `<%= typeof orderToEdit !== 'undefined' && orderToEdit ? JSON.stringify(orderToEdit) : 'null' %>`;
  const orderToEdit = JSON.parse(orderDataEl.textContent || 'null');

  const stockDataEl = document.createElement('span');
  stockDataEl.innerHTML = `<%= typeof stockInfo !== 'undefined' && stockInfo ? JSON.stringify(stockInfo) : 'null' %>`;
  const stockInfo = JSON.parse(stockDataEl.textContent || 'null');

  const confirmModeStr = `<%= typeof confirmMode !== 'undefined' && confirmMode ? 'true' : 'false' %>`;
  const confirmMode = confirmModeStr === 'true';

  const clientSelect = document.getElementById("client-name");
  const userSelect = document.getElementById("user-name");
  const userNameHidden = document.getElementById("user-name-hidden");
  const itemTypeSelect = document.getElementById("item-type");
  const itemSelect = document.getElementById("item-select");
  const sourceLocationInput = document.getElementById("source-location");
  const locationSelect = document.getElementById("user-location");
  const poNumberInput = document.getElementById("po-number");
  const rateDisplayInput = document.getElementById("item-rate");
  const orderRateInput = document.getElementById("order-rate");
  const quantityInput = document.getElementById("quantity");
  const estimatedDateInput = document.getElementById("estimated-date");
  const remarksInput = document.getElementById("remarks");
  const confirmQuantityInput = document.getElementById("confirm-quantity");
  const orderForm = document.querySelector("form");
  const submitButton = orderForm?.querySelector('button[type="submit"]');

  function normalizeLocationName(value) {
    return String(value || "")
      .trim()
      .toUpperCase()
      .replace(/\s+/g, " ")
      .replace(/^[.,]+|[.,]+$/g, "");
  }

  function normalizeLookupText(value) {
    return String(value || "")
      .trim()
      .replace(/\s+/g, " ");
  }

  function resolveSelectValue(selectEl, rawValue) {
    const target = normalizeLookupText(rawValue);
    if (!target || !selectEl?.options) return target;

    const targetLower = target.toLowerCase();
    for (const option of Array.from(selectEl.options)) {
      const optionValue = normalizeLookupText(option.value);
      const optionLabel = normalizeLookupText(option.textContent);
      if (optionValue.toLowerCase() === targetLower || optionLabel.toLowerCase() === targetLower) {
        return option.value;
      }
    }

    return target;
  }

  function setChoiceValue(choicesInstance, selectEl, rawValue) {
    if (!choicesInstance) return false;
    const resolvedValue = resolveSelectValue(selectEl, rawValue);
    if (!resolvedValue) return false;
    choicesInstance.setChoiceByValue(resolvedValue);
    return true;
  }

  let currentSourceLocation = "";
  function syncSourceLocation(value) {
    currentSourceLocation = normalizeLocationName(value);
    sourceLocationInput.value = currentSourceLocation;
  }

  let clientChoices, userChoices, locationChoices, itemTypeChoices, itemChoices;

  document.addEventListener("DOMContentLoaded", () => {
    // Initialize Choices.js for select fields
    clientChoices = new Choices(clientSelect, { searchEnabled: true, itemSelectText: "" });
    userChoices = new Choices(userSelect, { searchEnabled: true, itemSelectText: "" });
    locationChoices = new Choices(locationSelect, { searchEnabled: false, itemSelectText: "", shouldSort: false });
    itemTypeChoices = new Choices(itemTypeSelect, { searchEnabled: true, itemSelectText: "" });
    itemChoices = new Choices(itemSelect, { searchEnabled: true, itemSelectText: "" });
  });

  // Reset all downstream fields
  function resetUsers() {
    userChoices.clearStore();
    userChoices.setChoices([{ value: "", label: "Select User", disabled: true, selected: true }], "value", "label", true);
    userNameHidden.value = "";
    resetLocation();
    resetItems();
  }
  function resetLocation() {
    locationChoices.clearStore();
    locationChoices.setChoices([{ value: "", label: "Location", disabled: true, selected: true }], "value", "label", true);
  }
  function resetItems() {
    itemChoices.clearStore();
    itemChoices.setChoices([{ value: "", label: "Select Item", disabled: true, selected: true }], "value", "label", true);
    document.getElementById("stock-display").style.display = "none";
    syncSourceLocation("");
    if (rateDisplayInput) rateDisplayInput.value = "";
    if (orderRateInput) {
      orderRateInput.value = "";
      delete orderRateInput.dataset.userEdited;
      delete orderRateInput.dataset.fromOrder;
    }
  }

  // Load clients filtered by item type
  async function loadClients(itemType) {
    clientChoices.clearStore();
    clientChoices.setChoices([{ value: "", label: "Loading...", disabled: true, selected: true }], "value", "label", true);
    resetUsers();
    try {
      const res = await fetch(`/fairdesk/sales/clients/${itemType}`);
      const clientNames = await res.json();
      clientChoices.clearStore();
      clientChoices.setChoices(
        [{ value: "", label: "Select Client", disabled: true, selected: true },
         ...clientNames.map(name => ({ value: name, label: name }))],
        "value", "label", true
      );
    } catch (err) {
      console.error("Failed to load clients:", err);
      clientChoices.clearStore();
      clientChoices.setChoices([{ value: "", label: "Error loading clients", disabled: true, selected: true }], "value", "label", true);
    }
  }

  // Load users when client changes
  async function loadUsers(clientName, targetUserId = null, targetItemId = null) {
    if (!clientName) return;

    userChoices.clearStore();
    userChoices.setChoices([{ value: "", label: "Loading...", disabled: true, selected: true }], "value", "label", true);
    resetLocation();
    resetItems();

    try {
      const res = await fetch(`/fairdesk/form/labels/${encodeURIComponent(clientName)}`);
      const data = await res.json();
      const users = data.users || [];

      const choicesArray = users.map(user => ({
        value: user._id,
        label: user.userName,
        selected: user._id === targetUserId || (users.length === 1 && !targetUserId),
        customProperties: { name: user.userName, location: user.userLocation || "" }
      }));

      userChoices.clearStore();
      userChoices.setChoices(
        [{ value: "", label: "Select User", disabled: true, selected: !targetUserId && users.length !== 1 }, ...choicesArray],
        "value",
        "label",
        true
      );

      // Auto-select logic
      if (targetUserId) {
        const selected = users.find(u => u._id === targetUserId);
        if (selected) {
          userNameHidden.value = selected.userName || "";
          setLocationFromUser(selected);
          await loadItems(targetItemId);
        }
      } else if (users.length === 1) {
        userNameHidden.value = users[0].userName;
        setLocationFromUser(users[0]);
        await loadItems();
      }
    } catch (err) {
      console.error("Failed to load users:", err);
      userChoices.clearStore();
      userChoices.setChoices([{ value: "", label: "Error loading users", disabled: true, selected: true }], "value", "label", true);
    }
  }

  // Load items based on type and user
  async function loadItems(targetItemId = null) {
    const userId = userSelect.value;
    const itemType = itemTypeSelect.value;
    if (!userId || !itemType) return;

    itemChoices.clearStore();
    itemChoices.setChoices([{ value: "", label: "Loading...", disabled: true, selected: true }], "value", "label", true);

    try {
      const res = await fetch(`/fairdesk/sales/items/${itemType}/${userId}`);
      const items = await res.json();

      itemChoices.clearStore();
      if (items.length === 0) {
        itemChoices.setChoices([{ value: "", label: "No items found", disabled: true, selected: true }], "value", "label", true);
        return;
      }
      
      const itemChoicesArray = items.map(item => ({
        value: item._id,
        label: item.displayName,
        selected: item._id === targetItemId || (items.length === 1 && !targetItemId),
        customProperties: {
          stock: JSON.stringify(item.stock || { totalStock: 0, locations: [] }),
          minQty: item.minOrderQty || 0,
          rate: typeof item.rate !== "undefined" ? item.rate : null,
          details: JSON.stringify(item.details || {})
        }
      }));

      itemChoices.setChoices(
        [{ value: "", label: "Select Item", disabled: true, selected: !targetItemId && items.length !== 1 }, ...itemChoicesArray],
        "value",
        "label",
        true
      );
      
      // Trigger change event to update stock display
      updateStockDisplay();
    } catch (err) {
      console.error("Failed to load items:", err);
      itemChoices.clearStore();
      itemChoices.setChoices([{ value: "", label: "Error loading items", disabled: true, selected: true }], "value", "label", true);
    }
  }

  function updateRateDisplay(selectedOption) {
    if (!rateDisplayInput) return;
    const rate = selectedOption?.customProperties?.rate;
    const hasRate = rate === 0 || rate === "0" || (rate !== null && typeof rate !== "undefined" && rate !== "");
    rateDisplayInput.value = hasRate ? String(rate) : "";

    if (!orderRateInput) return;
    if (orderRateInput.dataset.userEdited === "true") return;
    if (orderRateInput.dataset.fromOrder === "true") return;
    orderRateInput.value = hasRate ? String(rate) : "";
  }

  function getProfileDetailEntries(details) {
    const d = details || {};
    const type = String(d.type || "").toUpperCase();
    const out = [];
    const pushIf = (label, value) => {
      if (value === null || value === undefined) return;
      const text = String(value).trim();
      if (!text) return;
      out.push([label, text]);
    };

    if (type === "TTR") {
      pushIf("Material Code", d.materialCode);
      pushIf("Type", d.ttrType);
      pushIf("Color", d.color);
      pushIf("Ink Face", d.inkFace);
      pushIf("Width", d.width);
      pushIf("Meters", d.mtrs);
      pushIf("Core ID", d.coreId);
      pushIf("Core Length", d.coreLength);
      pushIf("Notch", d.notch);
      pushIf("Winding", d.winding);
    } else if (type === "TAPE") {
      pushIf("Paper Code", d.paperCode);
      pushIf("GSM", d.gsm);
      pushIf("Paper Type", d.paperType);
      pushIf("Adhesive GSM", d.adhesiveGsm);
      pushIf("Width", d.width);
      pushIf("Meters", d.mtrs);
      pushIf("Core ID", d.coreId);
      pushIf("Finish", d.finish);
    } else if (type === "POS_ROLL") {
      pushIf("Paper Code", d.paperCode);
      pushIf("GSM", d.gsm);
      pushIf("Paper Type", d.paperType);
      pushIf("Color", d.color);
      pushIf("Width", d.width);
      pushIf("Meters", d.mtrs);
      pushIf("Core ID", d.coreId);
    } else if (type === "TAFETA") {
      pushIf("Material Code", d.materialCode);
      pushIf("GSM", d.gsm);
      pushIf("Material Type", d.materialType);
      pushIf("Color", d.color);
      pushIf("Width", d.width);
      pushIf("Meters", d.mtrs);
      pushIf("Core Length", d.coreLength);
      pushIf("Notch", d.notch);
      pushIf("Core ID", d.coreId);
    }

    return out;
  }

  async function updateStockDisplay() {
    const selectedOption = itemChoices.getValue(); // Choices.js object
    const stockDisplay = document.getElementById("stock-display");
    const detailsBox = document.getElementById("selected-item-details");
    updateRateDisplay(selectedOption);
    
    // Reset location selection
    sourceLocationInput.value = "";
    hideStockWarning();

    if (selectedOption && selectedOption.customProperties && selectedOption.customProperties.stock) {
      try {
        const details = JSON.parse(selectedOption.customProperties.details || "{}");
        const entries = getProfileDetailEntries(details);
        if (entries.length > 0) {
          detailsBox.innerHTML = `
            <div style="display:grid;grid-template-columns:repeat(4, minmax(0, 1fr));gap:4px 8px;">
              ${entries
                .map(([label, v]) => {
                  return `<div style="display:grid;grid-template-columns:180px 1fr;gap:8px;padding:4px 6px;border-bottom:1px solid #eef2f7;border-right:1px solid #e5e7eb;line-height:1.2;">
                    <div style="font-size:12px;color:#6b7280;">${label}</div>
                    <div style="font-size:12px;color:#111827;font-weight:600;">${v}</div>
                  </div>`;
                })
                .join("")}
            </div>
          `;
          detailsBox.style.display = "block";
        } else {
          detailsBox.style.display = "none";
          detailsBox.innerHTML = "";
        }
      } catch (_) {
        detailsBox.style.display = "none";
        detailsBox.innerHTML = "";
      }

      try {
        const stock = JSON.parse(selectedOption.customProperties.stock);
        
        const locRes = await fetch("/fairdesk/api/locations");
        const allLocations = await locRes.json();

        // Build "ALL" option
        let locationHtml = `<label class="location-option selected" data-location="ALL" data-qty="${stock.totalStock}" data-booked="${stock.booked || 0}" data-balance="${stock.balance || 0}">
              <input type="radio" name="locationRadio" class="location-radio" value="ALL" data-qty="${stock.totalStock}" data-booked="${stock.booked || 0}" data-balance="${stock.balance || 0}" checked />
              <span class="location-label">ALL:</span>
              <span class="location-qty">${stock.totalStock}</span>
            </label>`;

        // Build per-location options
        locationHtml += allLocations.map(locName => {
          const locData = (stock.locations || []).find(l => l.location === locName);
          const qty = locData ? locData.qty : 0;
          const booked = locData ? (locData.booked || 0) : 0;
          const balance = locData ? (locData.balance || 0) : 0;
          return `<label class="location-option" data-location="${locName}" data-qty="${qty}" data-booked="${booked}" data-balance="${balance}">
              <input type="radio" name="locationRadio" class="location-radio" value="${locName}" data-qty="${qty}" data-booked="${booked}" data-balance="${balance}" />
              <span class="location-label">${locName}:</span>
              <span class="location-qty">${qty}</span>
            </label>`;
        }).join("");

        stockDisplay.innerHTML = `
          <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; width: 100%;">
            <div style="display: flex; flex-wrap: wrap; align-items: center;">${locationHtml}</div>
            <div id="stock-stats" style="display: flex; gap: 14px; align-items: center; flex-wrap: wrap;">
              <div style="font-weight: 700; color: #044A78; font-size: 16px;">
                <i class="fa-solid fa-box-open"></i> Total: <span id="stat-total">${stock.totalStock}</span>
              </div>
              <div style="font-weight: 700; color: #d97706; font-size: 16px;" title="Pending Orders">
                <i class="fa-regular fa-clock"></i> Booked: <span id="stat-booked">${stock.booked || 0}</span>
              </div>
              <div style="font-weight: 700; color: #059669; font-size: 16px;" title="Available for new orders">
                <i class="fa-solid fa-scale-balanced"></i> Balance: <span id="stat-balance">${stock.balance || 0}</span>
              </div>
            </div>
          </div>
        `;
        stockDisplay.style.display = "block";

        // Attach radio button listeners
        stockDisplay.querySelectorAll('input[name="locationRadio"]').forEach(radio => {
          radio.addEventListener("change", function () {
            // Set source location (empty for ALL so validation catches it)
            syncSourceLocation(this.value === "ALL" ? "" : this.value);

            // Highlight selected
            stockDisplay.querySelectorAll('.location-option').forEach(el => el.classList.remove('selected'));
            this.closest('.location-option').classList.add('selected');

            // Update stats display
            document.getElementById("stat-total").textContent = this.dataset.qty;
            document.getElementById("stat-booked").textContent = this.dataset.booked;
            document.getElementById("stat-balance").textContent = this.dataset.balance;

            // Check quantity warning
            checkStockWarning();
          });
        });

        // ================= PRE-SELECT LOCATION =================
        // 1) Edit mode: prefer existing source location
        if (orderToEdit && orderToEdit.sourceLocation) {
          const editLocation = normalizeLocationName(orderToEdit.sourceLocation);
          const locRadio = stockDisplay.querySelector(`input[name="locationRadio"][value="${editLocation}"]`);
          if (locRadio) {
            locRadio.checked = true;
            locRadio.dispatchEvent(new Event('change'));
          }
        } else {
          // 2) Create mode: preselect user's location if available
          const userLocationValue = normalizeLocationName(locationSelect?.value || "");
          if (userLocationValue) {
            const userLocRadio = stockDisplay.querySelector(`input[name="locationRadio"][value="${userLocationValue}"]`);
            if (userLocRadio) {
              userLocRadio.checked = true;
              userLocRadio.dispatchEvent(new Event('change'));
            } else {
              // Fallback if stock widget doesn't contain this location
              syncSourceLocation(userLocationValue);
            }
          }
        }

      } catch (e) {
        console.error("Error parsing stock data", e);
        stockDisplay.style.display = "none";
      }
    } else {
      stockDisplay.style.display = "none";
      if (detailsBox) {
        detailsBox.style.display = "none";
        detailsBox.innerHTML = "";
      }
    }
  }

  function checkStockWarning() {
    const qty = parseInt(quantityInput.value) || 0;
    const selectedRadio = document.querySelector('input[name="locationRadio"]:checked');
    
    if (!selectedRadio || qty <= 0) {
      hideStockWarning();
      return;
    }
    
    const availableQty = parseInt(selectedRadio.dataset.qty) || 0;
    const warningDiv = document.getElementById("stock-warning");
    const warningText = document.getElementById("stock-warning-text");

    const isConfirmPage = window.location.pathname.includes('/sales/order/confirm');

    if (qty > availableQty && !isConfirmPage) {
      warningText.innerHTML = `Ordered quantity <b>${qty}</b> exceeds available stock <b>${availableQty}</b> at ${selectedRadio.value}. Order can still be created.`;
      warningDiv.style.display = "block";
    } else {
      hideStockWarning();
    }
  }

  function hideStockWarning() {
    document.getElementById("stock-warning").style.display = "none";
  }

  // Helper: set the Location choices field from a user object
  function setLocationFromUser(user) {
    if (!locationChoices) return;
    const loc = normalizeLocationName(user?.userLocation || "");
    locationChoices.clearStore();
    locationChoices.setChoices(
      loc ? [{ value: loc, label: loc, selected: true }] : [{ value: "", label: "N/A", disabled: true, selected: true }],
      "value", "label", true
    );
    locationSelect.value = loc;
    syncSourceLocation(loc);
  }

  function setLocationField(value) {
    if (!locationChoices) return;
    const loc = normalizeLocationName(value || "");
    locationChoices.clearStore();
    locationChoices.setChoices(
      loc ? [{ value: loc, label: loc, selected: true }] : [{ value: "", label: "N/A", disabled: true, selected: true }],
      "value",
      "label",
      true,
    );
    locationSelect.value = loc;
  }

  // ======= EVENT LISTENERS (Smart Cascading Filter) =======

  // 1. Item Type → filter clients, reset everything downstream
  itemTypeSelect.addEventListener("change", () => {
    const itemType = itemTypeSelect.value;
    if (itemType) loadClients(itemType);
  });

  // 2. Client → load filtered users, reset user/location/item
  clientSelect.addEventListener("change", () => {
    resetUsers();
    loadUsers(clientSelect.value);
  });

  locationSelect.addEventListener("change", () => {
    syncSourceLocation(locationSelect.value);
  });

  // 3. User → auto-fill location, reset + load items
  userSelect.addEventListener("change", () => {
    const selected = userChoices.getValue();
    userNameHidden.value = selected?.customProperties?.name || selected?.label || "";
    setLocationFromUser({ userLocation: selected?.customProperties?.location || "" });
    resetItems();
    loadItems();
  });

  // 4. Item → update stock display
  itemSelect.addEventListener("change", updateStockDisplay);
  quantityInput.addEventListener("input", checkStockWarning);
  if (orderRateInput) {
    orderRateInput.addEventListener("input", () => {
      orderRateInput.dataset.userEdited = "true";
    });
  }

  function getFieldLabel(field) {
    if (!field?.id) return "This field";
    const label = document.querySelector(`label[for="${field.id}"]`);
    if (!label) return "This field";
    return label.textContent.replace(/\*/g, "").trim() || "This field";
  }

  function getValidationMessage(field) {
    if (!field?.validity) return "Please check required fields.";
    if (field.validity.valueMissing) return `${getFieldLabel(field)} is required.`;
    if (field.validity.typeMismatch) return `Please enter a valid ${getFieldLabel(field).toLowerCase()}.`;
    if (field.validity.rangeUnderflow) return `${getFieldLabel(field)} is below allowed minimum.`;
    if (field.validity.rangeOverflow) return `${getFieldLabel(field)} exceeds allowed maximum.`;
    if (field.validity.stepMismatch) return `${getFieldLabel(field)} has an invalid value.`;
    if (field.validity.patternMismatch) return `${getFieldLabel(field)} format is invalid.`;
    return field.validationMessage || `Please enter a valid ${getFieldLabel(field).toLowerCase()}.`;
  }

  function getSelectedStockLocation() {
    const selectedRadio = document.querySelector('input[name="locationRadio"]:checked');
    const selectedChipLocation = normalizeLocationName(document.querySelector(".location-option.selected")?.dataset?.location || "");
    const radioLocation = normalizeLocationName(selectedRadio?.value || "");
    const fallbackLocation = normalizeLocationName(currentSourceLocation || sourceLocationInput.value || locationSelect.value || selectedChipLocation || "");
    return {
      selectedRadio,
      radioLocation,
      selectedLocation: radioLocation && radioLocation !== "ALL" ? radioLocation : fallbackLocation,
    };
  }

  function getAvailableStockForSelectedLocation(selectedRadio) {
    if (!selectedRadio) return 0;
    const balance = Number.parseInt(selectedRadio.dataset.balance || "", 10);
    if (Number.isFinite(balance)) return balance;
    const qty = Number.parseInt(selectedRadio.dataset.qty || "", 10);
    return Number.isFinite(qty) ? qty : 0;
  }

  function getAvailableStockForLocation(locationName) {
    const normalizedLocation = normalizeLocationName(locationName);
    if (!normalizedLocation) return 0;

    if (normalizedLocation === "ALL") {
      const totalBalance = Number.parseInt(stockInfo?.balance ?? stockInfo?.totalStock ?? 0, 10);
      return Number.isFinite(totalBalance) ? totalBalance : 0;
    }

    const locationEntry = (stockInfo?.locations || []).find((entry) => normalizeLocationName(entry?.location) === normalizedLocation);
    if (locationEntry) {
      const balance = Number.parseInt(locationEntry.balance ?? locationEntry.qty ?? 0, 10);
      return Number.isFinite(balance) ? balance : 0;
    }

    const selectedRadio = document.querySelector(`input[name="locationRadio"][value="${normalizedLocation}"]`);
    return getAvailableStockForSelectedLocation(selectedRadio);
  }

  function selectStockLocation(locationName) {
    const normalizedLocation = normalizeLocationName(locationName);
    if (!normalizedLocation) return false;

    const stockDisplay = document.getElementById("stock-display");
    const radio = stockDisplay?.querySelector(`input[name="locationRadio"][value="${normalizedLocation}"]`);
    if (!radio) return false;

    radio.checked = true;
    radio.dispatchEvent(new Event("change", { bubbles: true }));
    return true;
  }

  function setSubmittingState(isSubmitting) {
    if (!orderForm) return;
    orderForm.dataset.submitting = isSubmitting ? "1" : "0";
    if (submitButton) submitButton.disabled = !!isSubmitting;
  }

  function isTemplateOnlyInvoice(invoice) {
    const value = String(invoice || "").trim();
    if (!value) return true;
    return /^TECH\|\d{2}-\d{2}\|[A-Z_]+\|$/i.test(value);
  }

  // Form validation — prevent submit on invalid fields, disallow ALL location, and enforce min qty
  orderForm.addEventListener("submit", async function (e) {
    e.preventDefault();
    e.stopImmediatePropagation();
    if (orderForm.dataset.submitting === "1") return false;
    setSubmittingState(true);

    const firstInvalid = orderForm.querySelector(":invalid");
    if (firstInvalid) {
      showToast(getValidationMessage(firstInvalid), "error");
      firstInvalid.focus?.();
      setSubmittingState(false);
      return false;
    }

    const poValue = (poNumberInput?.value || "").trim();
    if (!poValue) {
      showToast("PO Number is required.", "error");
      poNumberInput?.focus?.();
      setSubmittingState(false);
      return false;
    }

    if (confirmMode) {
      const invoiceValue = (document.getElementById("invoice-number")?.value || "").trim();
      if (!invoiceValue || isTemplateOnlyInvoice(invoiceValue)) {
        showToast("Please enter Invoice Number before submitting the form.", "error");
        document.getElementById("invoice-number")?.focus?.();
        setSubmittingState(false);
        return false;
      }
    }

    const itemType = itemTypeSelect.value;
    const qty = parseInt(quantityInput.value) || 0;
    const selectedOption = itemChoices.getValue();
    const { selectedRadio, radioLocation, selectedLocation } = getSelectedStockLocation();
    
    // Check Source Location - ALL is not allowed for stock-based items
    if (itemType === "TAPE" || itemType === "POS_ROLL" || itemType === "TAFETA" || itemType === "TTR") {
      if (radioLocation === "ALL") {
        showToast("Location cannot be ALL. Please select a specific location.", "error");
        setSubmittingState(false);
        return false;
      }
      if (!selectedLocation) {
        showToast("no location is selected", "error");
        setSubmittingState(false);
        return false;
      }
      sourceLocationInput.value = selectedLocation;
    }

    const dispatchQty = confirmMode ? (parseInt(confirmQuantityInput?.value) || 0) : qty;
    if (confirmMode) {
      const confirmLocation = normalizeLocationName(sourceLocationInput.value || currentSourceLocation || selectedLocation || selectedRadio?.value || "");
      const availableQty = getAvailableStockForLocation(confirmLocation);
      if (dispatchQty > availableQty) {
        showToast("Cannot dispatch, Not enought stocks", "error");
        setSubmittingState(false);
        return;
      }
    }

    // Check Minimum Order Qty
    if (selectedOption && selectedOption.customProperties) {
      const minQty = parseInt(selectedOption.customProperties.minQty) || 0;
      if (qty < minQty) {
        showToast(`Order quantity (${qty}) is less than Minimum Order Quantity (${minQty}).`, "error");
        setSubmittingState(false);
        return;
      }
    }

    // For create/update sales order, submit via AJAX so backend JSON errors show as toast
    const actionPath = orderForm.getAttribute("action") || "";
    if (actionPath === "/fairdesk/sales/order") {
      try {
        const formData = new FormData(orderForm);
        const payload = new URLSearchParams();
        for (const [key, value] of formData.entries()) {
          payload.append(key, value);
        }

        const res = await fetch(actionPath, {
          method: "POST",
          headers: {
            "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8",
            "Accept": "application/json"
          },
          body: payload.toString()
        });

        let data = null;
        try {
          data = await res.json();
        } catch (_) {
          data = null;
        }

        if (!res.ok || (data && data.success === false)) {
          showToast(data?.message || "Failed to submit order", "error");
          setSubmittingState(false);
          return false;
        }

        if (data?.redirect) {
          window.location.href = data.redirect;
          return true;
        }

        showToast("Sales order submitted successfully", "success");
        window.location.reload();
        return true;
      } catch (err) {
        console.error("Sales order submit error:", err);
        showToast("Network error while submitting order", "error");
        setSubmittingState(false);
        return false;
      }
    }

    orderForm.submit();
    return true;
  });

  // Toast Function
  function showToast(message, type = "info") {
    // Create toast container if not exists
    let container = document.getElementById("toast-container");
    if (!container) {
      container = document.createElement("div");
      container.id = "toast-container";
      container.style.cssText = "position: fixed; bottom: 20px; right: 20px; z-index: 9999; display: flex; flex-direction: column; gap: 10px;";
      document.body.appendChild(container);
    }

    const toast = document.createElement("div");
    toast.textContent = message;
    
    // Style based on type (supports "error", "success", true/false)
    const isError = type === "error" || type === true;
    const isSuccess = type === "success" || type === false;
    const bg = isError ? "#fee2e2" : (isSuccess ? "#dcfce7" : "#e0f2fe");
    const color = isError ? "#991b1b" : (isSuccess ? "#166534" : "#075985");
    const border = isError ? "#f87171" : (isSuccess ? "#22c55e" : "#38bdf8");

    toast.style.cssText = `
      padding: 12px 24px;
      background: ${bg};
      color: ${color};
      border-left: 5px solid ${border};
      border-radius: 4px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
      font-weight: 500;
      min-width: 300px;
      opacity: 0;
      transform: translateX(100%);
      transition: all 0.3s ease;
    `;

    container.appendChild(toast);

    // Animate In
    requestAnimationFrame(() => {
      toast.style.opacity = "1";
      toast.style.transform = "translateX(0)";
    });

    // Remove after 3s
    setTimeout(() => {
      toast.style.opacity = "0";
      toast.style.transform = "translateX(100%)";
      setTimeout(() => toast.remove(), 300);
    }, 4000);
  }

  // Pre-fill form from URL params or Order Data
  window.addEventListener("DOMContentLoaded", async () => {
    // Restore scroll position after log edit/delete reload
    const savedScroll = sessionStorage.getItem('logEditScrollY');
    if (savedScroll !== null) {
      sessionStorage.removeItem('logEditScrollY');
      requestAnimationFrame(() => window.scrollTo(0, parseInt(savedScroll)));
    }
    const params = new URLSearchParams(window.location.search);
    let type = normalizeLookupText(params.get("type"));
    let client = normalizeLookupText(params.get("client"));
    let userId = normalizeLookupText(params.get("user"));
    let itemId = normalizeLookupText(params.get("item"));

    // Fallback to orderToEdit if params are missing (Robust Prefill)
    if (orderToEdit) {
      if (!type && orderToEdit.tapeBinding) type = "TAPE"; 
      if (!client && orderToEdit.userId && orderToEdit.userId.clientName) client = normalizeLookupText(orderToEdit.userId.clientName);
      if (!userId && orderToEdit.userId && orderToEdit.userId._id) userId = String(orderToEdit.userId._id);
      // Check if tapeBinding is populated or ID
      if (!itemId && orderToEdit.tapeBinding && orderToEdit.tapeBinding._id) itemId = String(orderToEdit.tapeBinding._id);
      else if (!itemId && orderToEdit.tapeBinding) itemId = String(orderToEdit.tapeBinding);
    }

    // ==========================================
    // CONFIRM MODE OPTIMIZATION (INSTANT LOAD)
    // ==========================================
    if (confirmMode && orderToEdit) {
      if (client) {
         // 1. Set Client & Type
         if (type) itemTypeChoices.setChoiceByValue(type);
         clientChoices.setChoiceByValue(client);
         
         // 2. Set User (Manually create option)
         userChoices.clearStore();
         userChoices.setChoices([{
            value: userId,
            label: orderToEdit.userId.userName || "User",
            selected: true,
            customProperties: {
              name: orderToEdit.userId.userName || "User",
              location: orderToEdit.userId.userLocation || ""
            }
         }], "value", "label", true);
         
         userNameHidden.value = orderToEdit.userId.userName || "User";

         // 3. Set Item (Manually create option with injected stock)
         let tapeName = "Item";
         if (orderToEdit.tapeId) {
            const t = orderToEdit.tapeId;
            if (t.tapePaperCode) tapeName = t.tapePaperCode + " " + t.tapeGsm + "gsm";
            else if (t.posPaperCode) tapeName = t.posPaperCode + " " + t.posGsm + "gsm";
            else if (t.tafetaMaterialCode) tapeName = t.tafetaMaterialCode + " " + t.tafetaGsm + "gsm";
            else if (t.ttrProductId) {
              const parts = [
                t.ttrType,
                t.ttrWidth ? `${t.ttrWidth}` : null,
                t.ttrMtrs ? `${t.ttrMtrs}m` : null,
              ].filter(Boolean);
              tapeName = `${parts[0] || t.ttrProductId || "Item"} ${parts.slice(1).join(" ")}`.trim();
            }
         }
         
         itemChoices.clearStore();
          itemChoices.setChoices([{
             value: itemId,
             label: tapeName,
             selected: true,
             customProperties: {
                stock: stockInfo ? JSON.stringify(stockInfo) : JSON.stringify({ totalStock: 0, locations: [] }),
                minQty: orderToEdit.tapeBinding
                  ? (orderToEdit.tapeBinding.tapeMinQty ??
                    orderToEdit.tapeBinding.posMinQty ??
                    orderToEdit.tapeBinding.tafetaMinQty ??
                    orderToEdit.tapeBinding.ttrMinQty ??
                    0)
                  : 0,
                rate: orderToEdit.tapeBinding
                  ? (orderToEdit.tapeBinding.tapeRatePerRoll ??
                    orderToEdit.tapeBinding.posRatePerRoll ??
                    orderToEdit.tapeBinding.tafetaRatePerRoll ??
                    orderToEdit.tapeBinding.ttrRatePerRoll ??
                    0)
                  : null
             }
          }], "value", "label", true);

          // 4. Update Stock Display
          await updateStockDisplay();
          if (orderToEdit.sourceLocation) {
            selectStockLocation(orderToEdit.sourceLocation);
          } else if (orderToEdit.userId?.userLocation) {
            selectStockLocation(orderToEdit.userId.userLocation);
          }

         // 5. Pre-fill confirm fields
         const today = new Date();
         const yyyy = today.getFullYear();
         const mm = String(today.getMonth() + 1).padStart(2, '0');
         const dd = String(today.getDate()).padStart(2, '0');
         const confirmDateInput = document.getElementById('confirm-date');
         const confirmQtyInput = document.getElementById('confirm-quantity');
         const invoiceInput = document.getElementById('invoice-number');
         
         if (confirmDateInput) confirmDateInput.value = `${yyyy}-${mm}-${dd}`;
         if (confirmQtyInput) confirmQtyInput.value = (orderToEdit.quantity - (orderToEdit.dispatchedQuantity || 0));
         
         if (invoiceInput) {
           const currentMonth = today.getMonth() + 1; // 1-12
           const startYear = currentMonth < 4 ? yyyy - 1 : yyyy;
           const endYear = startYear + 1;
           const finYearStr = `${String(startYear).slice(-2)}-${String(endYear).slice(-2)}`;
           let typePrefix = type || itemTypeChoices.getValue(true) || "";
           if (typePrefix === "POS_ROLL") typePrefix = "POSROLL";
           
           if (typePrefix) {
             invoiceInput.value = `TECH|${finYearStr}|${typePrefix}|`;
           }
         }

         // 6. Pre-fill Original Order Fields
         if (orderToEdit.poNumber) poNumberInput.value = orderToEdit.poNumber;
         if (orderRateInput && typeof orderToEdit.orderRate !== "undefined" && orderToEdit.orderRate !== null) {
           orderRateInput.value = String(orderToEdit.orderRate);
           orderRateInput.dataset.fromOrder = "true";
         }
         if (orderToEdit.userId?.userLocation) {
           setLocationField(orderToEdit.userId.userLocation);
         }
         if (orderToEdit.quantity) quantityInput.value = orderToEdit.quantity;
         if (orderToEdit.remarks) remarksInput.value = orderToEdit.remarks;
         if (orderToEdit.estimatedDate) {
            const d = new Date(orderToEdit.estimatedDate);
            const yyyy = d.getFullYear();
            const mm = String(d.getMonth() + 1).padStart(2, '0');
            const dd = String(d.getDate()).padStart(2, '0');
            estimatedDateInput.value = `${yyyy}-${mm}-${dd}`;
         }

         // 7. Disable fields
         itemTypeChoices.disable();
         clientChoices.disable();
         userChoices.disable();
         itemChoices.disable();
         quantityInput.readOnly = true;
         poNumberInput.readOnly = !!orderToEdit.poNumber;
         if (orderRateInput) orderRateInput.readOnly = true;
         estimatedDateInput.readOnly = true;
         remarksInput.readOnly = true;
         locationChoices.disable();

         // EXIT early - do not run standard load logic
         return;
      }
    }

    if (type) {
      await loadClients(type);
      setChoiceValue(itemTypeChoices, itemTypeSelect, type);
    }

    if (client) {
      const decodedClient = normalizeLookupText(client);
      const selectedClient = setChoiceValue(clientChoices, clientSelect, decodedClient)
        ? resolveSelectValue(clientSelect, decodedClient)
        : decodedClient;

      if (selectedClient) {
        await loadUsers(selectedClient, userId || null, itemId || null);
      }
    }

    // Pre-fill specific order fields if editing (STANDARD MODE)
    if (orderToEdit && !confirmMode) {
      if (orderToEdit.poNumber) poNumberInput.value = orderToEdit.poNumber;
      if (orderRateInput && typeof orderToEdit.orderRate !== "undefined" && orderToEdit.orderRate !== null) {
        orderRateInput.value = String(orderToEdit.orderRate);
        orderRateInput.dataset.fromOrder = "true";
      }
      if (orderToEdit.userId?.userLocation) setLocationFromUser(orderToEdit.userId);
      if (orderToEdit.quantity) quantityInput.value = orderToEdit.quantity;
      if (orderToEdit.remarks) remarksInput.value = orderToEdit.remarks;
      if (orderToEdit.estimatedDate) {
        // Format date to YYYY-MM-DD
        const d = new Date(orderToEdit.estimatedDate);
        const yyyy = d.getFullYear();
        const mm = String(d.getMonth() + 1).padStart(2, '0');
        const dd = String(d.getDate()).padStart(2, '0');
        estimatedDateInput.value = `${yyyy}-${mm}-${dd}`;
      }

      // Keep edit-order page fully editable.
      itemTypeChoices?.enable();
      clientChoices?.enable();
      userChoices?.enable();
      itemChoices?.enable();
      locationChoices?.enable();
      quantityInput.readOnly = false;
      poNumberInput.readOnly = false;
      if (orderRateInput) orderRateInput.readOnly = false;
      estimatedDateInput.readOnly = false;
      remarksInput.readOnly = false;
    }


  });

  // ================= LOG EDIT / DELETE HANDLERS =================
  function openEditDialog(logId, qty, invoice, date) {
    document.getElementById('edit-log-id').value = logId;
    document.getElementById('edit-log-qty').value = qty;
    document.getElementById('edit-log-invoice').value = invoice;
    document.getElementById('edit-log-date').value = date;
    document.getElementById('edit-log-dialog').style.display = 'flex';
  }

  function closeEditDialog() {
    document.getElementById('edit-log-dialog').style.display = 'none';
  }

  function confirmDeleteLog(logId) {
    document.getElementById('delete-log-id').value = logId;
    document.getElementById('delete-log-dialog').style.display = 'flex';
  }

  function closeDeleteDialog() {
    document.getElementById('delete-log-dialog').style.display = 'none';
  }
  
  async function refreshLogsSection() {
    try {
      const res = await fetch(window.location.href);
      const html = await res.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');
      
      const currentLogs = document.getElementById('logs-wrapper');
      const newLogs = doc.getElementById('logs-wrapper');
      if (currentLogs && newLogs) {
        currentLogs.innerHTML = newLogs.innerHTML;
      }

      const currentConfirmQty = document.getElementById('confirm-quantity');
      const newConfirmQty = doc.getElementById('confirm-quantity');
      if (currentConfirmQty && newConfirmQty) {
        currentConfirmQty.value = newConfirmQty.value;
      }

      // Extract new stockInfo from the HTML script tags 
      const scripts = doc.getElementsByTagName('script');
      for (let s of scripts) {
        if (s.textContent.includes('const stockInfo =')) {
          const match = s.textContent.match(/const stockInfo = (.*?);/);
          if (match && match[1] && match[1] !== 'null') {
            try {
               const newStockData = JSON.parse(match[1]);
               const itemOpt = document.querySelector('#item-select option');
               if (itemOpt) {
                 itemOpt.dataset.stock = JSON.stringify(newStockData);
                 updateStockDisplay();
               }
            } catch(e) { console.error("Error parsing new stock info", e); }
            break;
          }
        }
      }
    } catch (err) {
      console.error("Failed to refresh logs smoothly", err);
      window.location.reload(); // Fallback
    }
  }

  async function submitEditLog() {
    const logId = document.getElementById('edit-log-id').value;
    const qty = parseInt(document.getElementById('edit-log-qty').value);
    const invoiceNumber = document.getElementById('edit-log-invoice').value.trim();
    const date = document.getElementById('edit-log-date').value;

    if (!qty || qty < 1) {
      showToast('Quantity must be at least 1.', 'error');
      return;
    }

    try {
      const res = await fetch(`/fairdesk/sales/order/log/${logId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ quantity: qty, invoiceNumber, date })
      });
      const data = await res.json();
      if (data.success) {
        showToast('Log updated successfully!', false);
        await refreshLogsSection();
      } else {
        showToast(data.message || 'Failed to update log.', 'error');
      }
    } catch (err) {
      console.error('Edit log error:', err);
      showToast('Something went wrong.', 'error');
    }
    closeEditDialog();
  }

  async function submitDeleteLog() {
    const logId = document.getElementById('delete-log-id').value;

    try {
      const res = await fetch(`/fairdesk/sales/order/log/${logId}`, {
        method: 'DELETE'
      });
      const data = await res.json();
      if (data.success) {
        showToast('Log deleted successfully!', false);
        await refreshLogsSection();
      } else {
        showToast(data.message || 'Failed to delete log.', 'error');
      }
    } catch (err) {
      console.error('Delete log error:', err);
      showToast('Something went wrong.', 'error');
    }
    closeDeleteDialog();
  }
</script>
