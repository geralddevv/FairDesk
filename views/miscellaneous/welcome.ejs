<% layout('/layout/boilerplate') %>

<div class="contain" style="flex-direction: column; align-items: center; justify-content: center; height: 80vh; text-align: center; gap: 20px;">
    <div style="background: white; padding: 40px 60px; border-radius: 20px; box-shadow: 0 10px 30px rgba(4, 74, 120, 0.1); border: 1px solid rgba(4, 74, 120, 0.05);">
        <div style="width: 100px; height: 100px; background: #f0f7ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; overflow: hidden; box-shadow: 0 4px 15px rgba(4, 74, 120, 0.15); border: 2px solid #ffffff;">
            <% if (authUser?.empPhoto) { %>
                <img src="/images/empimg/<%= authUser.empPhoto %>" alt="Profile" style="width: 100%; height: 100%; object-fit: cover;">
            <% } else { %>
                <img src="/assets/fairfavicon.png" alt="Fairdesk" style="width: 60%; height: 60%; object-fit: contain;">
            <% } %>
        </div>
        
        <h1 style="color: #03365a; font-weight: 800; font-size: 2.5rem; margin-bottom: 8px; line-height: 1.2;">
            Welcome,<br>
            <%= authUser?.empName || authUser?.username %>!
        </h1>
        <p style="color: #64748b; font-size: 1.1rem; max-width: 400px; margin: 0 auto 32px;">We're glad to see you back. Use the sidebar to navigate through your Fairtech dashboard.</p>
        
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 24px;">
            <div style="background: #f8fafc; padding: 16px; border-radius: 12px; border: 1.5px solid #f1f5f9;">
                <span style="display: block; font-size: 12px; color: #94a3b8; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 4px;">Name</span>
                <span style="font-weight: 700; color: #044a78;"><%= authUser?.empName || authUser?.username %></span>
            </div>
            <div style="background: #f8fafc; padding: 16px; border-radius: 12px; border: 1.5px solid #f1f5f9;">
                <span style="display: block; font-size: 12px; color: #94a3b8; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 4px;">Profile Code</span>
                <span style="font-weight: 700; color: #044a78;"><%= authUser?.profileCode || 'N/A' %></span>
            </div>
            <div style="background: #f8fafc; padding: 16px; border-radius: 12px; border: 1.5px solid #f1f5f9;">
                <span style="display: block; font-size: 12px; color: #94a3b8; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 4px;">Role</span>
                <span style="font-weight: 700; color: #044a78;"><%= authUser?.role.toUpperCase() %></span>
            </div>
            <div style="background: #f8fafc; padding: 16px; border-radius: 12px; border: 1.5px solid #f1f5f9;">
                <span style="display: block; font-size: 12px; color: #94a3b8; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 4px;">Today</span>
                <span style="font-weight: 700; color: #044a78;"><%= new Date().toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></span>
            </div>
        </div>

        <!-- Motivational Quote Section -->
        <div id="quote-container" style="padding: 30px; background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%); border-radius: 16px; border: 1px solid #e2e8f0; position: relative; overflow: hidden; opacity: 0; transform: translateY(10px); transition: all 0.6s ease-out; text-align: center;">
            <i class="fa-solid fa-quote-left" style="position: absolute; top: 10px; left: 10px; font-size: 28px; color: #044a78; opacity: 0.1;"></i>
            <p id="quote-text" style="color: #03365a; font-size: 1.6rem; font-style: italic; margin: 0; line-height: 1.6; font-weight: 600;">"Loading inspiration..."</p>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async () => {
        const container = document.getElementById('quote-container');
        const textEl = document.getElementById('quote-text');

        try {
            const response = await fetch('/fairdesk/api/motivational?t=' + Date.now());
            if (!response.ok) {
                throw new Error(`Quote request failed with ${response.status}`);
            }
            const data = await response.json();
            
            if (data && data.q) {
                textEl.innerText = `"${data.q}"`;
            }
        } catch (error) {
            console.error('Error fetching quote:', error);
            textEl.innerText = '"Quality is not an act, it is a habit."';
        } finally {
            // Animate in
            container.style.opacity = '1';
            container.style.transform = 'translateY(0)';
        }
    });
</script>

<style>
    @keyframes wave {
        0%, 100% { transform: rotate(0deg); }
        25% { transform: rotate(-15deg); }
        75% { transform: rotate(15deg); }
    }
</style>
