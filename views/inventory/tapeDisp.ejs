<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />
<link href="https://unpkg.com/tabulator-tables@5.6.2/dist/css/tabulator_modern.min.css" rel="stylesheet">
</head>

<body>
<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px" >
      <div class="indi-head">
        <h1>Tapes</h1>
        <div class="download-btns">
          <div class="download-selector" id="downloadSelector">
            <button class="download-selector__trigger">
              <span>
                <i class="fa-solid fa-file-arrow-down"></i>
                <span class="download-typo">Download</span>
              </span>
              <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
            </button>
            <div class="download-selector__menu" id="downloads">
              <span class="download-selector__option" id="download-pdf">
                <i class="fas fa-file-pdf download-selector__option-icon"></i>
                <span>PDF</span>
              </span>
              <span class="download-selector__option" id="download-xlsx">
                <i class="fas fa-file-excel download-selector__option-icon"></i>
                <span>Excel</span>
              </span>
            </div>
          </div>
      </div>
    </div>

    <div class="table-spinner"><div class="spinner-circle"></div></div>
    <div id="master-table" class="tabulator tabulator-modern"></div>
</div>

  <!-- Tabulator JS -->
  <script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>

  <script id="table-data" type="application/json"><%- JSON.stringify(jsonData) %></script>
  <script>
    // Render data from Express (passed into EJS)
    const rawData = JSON.parse(document.getElementById('table-data').textContent);

    // Flatten nested fields so Tabulator headerFilter works correctly
    const tableData = rawData.map(row => ({
      ...row,
      _userName: row.userId?.userName || "",
      _userContact: row.userId?.userContact || "",
      _userLocation: row.userId?.hoLocation || "",
      _clientName: row.userId?.clientName || "",
      _tapePaperType: row.tapeId?.tapePaperType || "",
      _tapeWidth: row.tapeId?.tapeWidth || "",
      _tapeMtrs: row.tapeId?.tapeMtrs || "",
      _tapeCoreId: row.tapeId?.tapeCoreId || "",
      _tapeMasterId: row.tapeId?._id || "",
    }));

    // Initialize Tabulator
    const table = new Tabulator("#master-table", {
      data: tableData,
      layout: "fitDataTable",
      responsiveLayout: false,
      pagination: "local",
      paginationSize: 30,
      movableColumns: true,
      placeholder: "No data to display",
      columns: [
        {
          title: "",
          formatter: function (cell) {
            const row = cell.getRow().getData();
            if (!row._tapeMasterId) return `<span style="color:#999">N/A</span>`;
            return `
              <button 
                onclick="window.location.href='/fairdesk/tape/profile/${row._tapeMasterId}'"
                style="padding:2px 10px;background:#044A78;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;">
                <i class="fa-solid fa-eye"></i>
              </button>
            `;
          }
        },
        {
          title: "",
          hozAlign: "center",
          formatter: function (cell) {
            const row = cell.getRow().getData();
            if (!row._id) return '';
            return `
              <button 
                onclick="window.location.href='/fairdesk/tape-binding/edit/${row._id}'"
                style="padding:2px 10px;background:#e67e22;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;"
                title="Edit Binding">
                <i class="fa-solid fa-pen-to-square"></i>
              </button>
            `;
          }
        },
        {
          title: "Status",
          field: "status",
          hozAlign: "center",
          headerFilter: "input",
          headerFilterPlaceholder: "Filter",
          formatter: function (cell) {
            const val = cell.getValue() || "ACTIVE";
            const isActive = val === "ACTIVE";
            const bg = isActive ? "#28a745" : "#dc3545";
            return `<span style="background:${bg};color:#fff;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;">${val}</span>`;
          }
        },
        {
          title: "Stock",
          field: "stock",
          hozAlign: "center",
          formatter: (cell) => {
            const row = cell.getRow().getData();
            const stock = row.stock ?? "-";
            return `<span style="font-weight:600">${stock}</span>`;
          }
        },
        {
          title: "Order",
          hozAlign: "center",
          formatter: (cell) => {
            const row = cell.getRow().getData();
            return `
              <button 
                onclick="window.location.href='/fairdesk/sales/order?type=TAPE&client=${encodeURIComponent(row._clientName)}&user=${row.userId?._id || ""}&item=${row._id}'"
                style="padding:2px 10px;background:#044A78;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;">
                <i class="fa-solid fa-cart-plus"></i>
              </button>
            `;
          }
        },
        { title: "User Name", field: "_userName", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "User Contact", field: "_userContact", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Location", field: "_userLocation", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Client GSM", field: "clientTapeGsm", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Paper Type", field: "_tapePaperType", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Width", field: "_tapeWidth", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Mtrs", field: "_tapeMtrs", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Mtrs Del", field: "tapeMtrsDel", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Core ID", field: "_tapeCoreId", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Rate Per Roll", field: "tapeRatePerRoll" },
        { title: "Min Qty", field: "tapeMinQty" },
        { title: "Order Qty", field: "tapeOdrQty" },
      ]
    });

    // Dropdown toggle
    const selector = document.getElementById("downloadSelector");
    const trigger = selector.querySelector(".download-selector__trigger");

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      selector.classList.toggle("download-selector--active");
    });

    // Close dropdown on outside click
    document.addEventListener("click", () => {
      selector.classList.remove("download-selector--active");
    });

    // PDF download
    document.getElementById("download-pdf").addEventListener("click", () => {
      table.download("pdf", "tapes.pdf", {
        orientation: "landscape",
        title: "Tapes Data",
      });
      selector.classList.remove("download-selector--active");
    });

    // Excel download
    document.getElementById("download-xlsx").addEventListener("click", () => {
      table.download("xlsx", "tape.xlsx", {
        sheetName: "Tapes",
      });
      selector.classList.remove("download-selector--active");
    });

  </script>
</body>