<!--- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }

  .custom-scrollbar::-webkit-scrollbar-track {
    background: #f0f2f5;
  }

  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #044A78;
    border-radius: 6px;
  }

  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #044A78;
  }

  .custom-scrollbar {
    scrollbar-width: thin;
    scrollbar-color: #044A78 #f0f2f5;
  }

  .custom-scrollbar input[type="checkbox"] {
    accent-color: #044A78;
  }
</style>

<div class="main-content">
  <div>
    <div class="span-full form-subheading gap" style="margin-bottom: 1rem;">
      <div class="client-switch active">
        <h1>Create Vendor</h1>
      </div>
      <div class="user-switch">
        <h1>Create Vendor Coordinator</h1>
      </div>
    </div>       
    <form id="vendor-form" class="client-content span-full needs-validation" action="/fairdesk/form/vendor" method="post" autocomplete="off" novalidate>
    <div class="span-five">
      <label for="client-id">Vendor Id</label>
      <input type="text" value="FS | VENDOR | <%= vendorCount + 1 %>" id="client-id" class="form-control input-tag" name="vendorId" placeholder="Enter Vendor ID" readonly required />
    </div>      
    <div class="span-six">
      <label for="client-name">Vendor Name</label>
      <input type="text" id="client-name" class="form-control input-tag" name="vendorName" placeholder="Enter Vendor Name" required />
    </div>

    <div class="span-six">
      <label for="client-status">Vendor Status</label>
      <select name="vendorStatus" id="client-status" class="form-control select-tag" required>
        <!-- <option value="" selected disabled hidden>Select</option> -->
        <option value="ACTIVE" selected>ACTIVE</option>
        <option value="INACTIVE">INACTIVE</option>
        <option value="BLACKLISTED">BLACKLISTED</option>
        <option value="OTHERS">OTHERS</option>
      </select>
    </div>

    <div class="span-seven">
      <label for="ho-location">H/O Location</label>
      <input type="text" id="ho-location" class="form-control input-tag" name="hoLocation" placeholder="Enter H/O Location" required />
    </div>

    <div class="span-eight">
      <label for="warehouse-location">Warehouse Location</label>
      <input type="text" id="warehouse-location" class="form-control input-tag" name="warehouseLocation" placeholder="Enter Warehouse Location" required />
    </div>

    <div class="span-full form-subheading">
      <h1>Commodities</h1>
    </div>

    <div class="span-full">
      <div class="custom-scrollbar" style="display: flex; flex-wrap: nowrap; align-items: center; justify-content: space-between; width: 100%; white-space: nowrap; overflow-x: auto; padding: 8px 14px; background: #e9f0f6; border-radius: 8px; column-gap: 24px;">
        <label style="display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 4px 8px; background: transparent;">
          <input type="checkbox" name="commodities" value="Face Paper" style="width: 16px; height: 16px;">
          Face Paper
        </label>
        <label style="display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 4px 8px; background: transparent;">
          <input type="checkbox" name="commodities" value="Adhesive" style="width: 16px; height: 16px;">
          Adhesive
        </label>
        <label style="display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 4px 8px; background: transparent;">
          <input type="checkbox" name="commodities" value="Release Paper" style="width: 16px; height: 16px;">
          Release Paper
        </label>
        <label style="display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 4px 8px; background: transparent;">
          <input type="checkbox" name="commodities" value="SL (Paper)" style="width: 16px; height: 16px;">
          SL (Paper)
        </label>
        <label style="display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 4px 8px; background: transparent;">
          <input type="checkbox" name="commodities" value="Packaging" style="width: 16px; height: 16px;">
          Packaging
        </label>
        <label style="display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 4px 8px; background: transparent;">
          <input type="checkbox" name="commodities" value="TTR" style="width: 16px; height: 16px;">
          TTR
        </label>
        <label style="display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 4px 8px; background: transparent;">
          <input type="checkbox" name="commodities" value="Tape" style="width: 16px; height: 16px;">
          Tape
        </label>
        <label style="display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 4px 8px; background: transparent;">
          <input type="checkbox" name="commodities" value="POS Roll" style="width: 16px; height: 16px;">
          POS Roll
        </label>
        <label style="display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 4px 8px; background: transparent;">
          <input type="checkbox" name="commodities" value="Taffeta" style="width: 16px; height: 16px;">
          Taffeta
        </label>
        <label style="display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 4px 8px; background: transparent;">
          <input type="checkbox" name="commodities" value="IT" id="commodity-it" style="width: 16px; height: 16px;">
          IT
        </label>
        <label style="display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 4px 8px; background: transparent;">
          <input type="checkbox" name="commodities" value="Others" id="commodity-others" style="width: 16px; height: 16px;">
          Others
        </label>
      </div>
    </div>

    <!-- <div class="span-seven">
      <label for="owner-name">Owner Name</label>
      <input type="text" id="owner-name" class="form-control input-tag" name="ownerName" placeholder="Enter Owner Name" />
    </div>

    <div class="span-six">
      <label for="owner-mob-no">Owner Mob. No.</label>
      <input type="text" id="owner-mob-no" class="form-control input-tag" name="ownerMobNo" placeholder="Enter Owner Mob. No." />
    </div>

    <div class="span-six">
      <label for="owner-email">Owner Email</label>
      <input type="email" id="owner-email" class="form-control" name="ownerEmail" placeholder="Enter Owner Email" />
    </div> -->

    <div class="span-full form-subheading"></div>    

    <div class="span-dual">
      <label for="client-gst">GST</label>
      <input type="text" maxlength="15" id="client-gst" class="form-control" name="vendorGst" placeholder="Enter GST" required />
    </div>

    <div class="span-dual">
      <label for="client-msme">MSME</label>
      <input type="text" maxlength="15" id="client-msme" class="form-control" name="vendorMsme" placeholder="Enter MSME" required />
    </div> 
    <div class="span-dual">
      <label for="client-gumasta">Gumasta</label>
      <input type="text" id="client-gumasta" class="form-control" name="vendorGumasta" placeholder="Enter GUMASTA" required />
    </div> 
    <div class="span-dual">
      <label for="client-pan">PAN</label>
      <input type="text" maxlength="10" id="client-pan" class="form-control" name="vendorPan" placeholder="Enter PAN" required />
    </div> 

    <div class="span-full btn-grp">
      <button id="vendor-submit-btn" class="submit-btn" type="submit">Save Vendor Details</button>
    </div>
  </form>

  <!---------------------------------------------------------------------------------------------------------------------------------------------->
    <form id="vendor-user-form" action="/fairdesk/form/vendor-user" method="post" class="user-content span-full needs-validation" autocomplete="off" novalidate>
    <div class="span-full form-subheading">
      <h1>Vendor Information</h1>
    </div>
    <!-- Username -->

    <div class="span-dual">
      <label for="userform-client-name">Vendor Name</label>
      <select name="vendorName" id="userform-client-name">
        <option value="" disabled selected hidden>Search</option>        
        <% for (vendor of vendors) { %>
          <option value="<%= vendor %>"><%= vendor %></option>
        <% } %>
      </select>
    </div>

    <div class="span-five">
      <label for="user-client-id">Vendor Id</label>
      <input id="user-client-id" class="form-control input-tag" name="vendorId" placeholder="Enter Vendor ID" readonly required />
    </div>
    
    <div class="span-five">
      <label for="coordinator-vendor-status">Vendor Status</label>
      <select name="vendorStatus" id="coordinator-vendor-status" class="form-control select-tag" required>
        <option value="" selected disabled hidden>Select</option>
        <option value="ACTIVE">ACTIVE</option>
        <option value="INACTIVE">INACTIVE</option>
        <option value="BLACKLISTED">BLACKLISTED</option>
        <option value="OTHERS">OTHERS</option>
      </select>
    </div>    

    <div class="span-seven">
      <label for="coordinator-ho-location">H/O Location</label>
      <input type="text" id="coordinator-ho-location" class="form-control input-tag" name="hoLocation" placeholder="Enter H/O Location" readonly required />
    </div>

    <div class="span-seven">
      <label for="coordinator-warehouse-location">Warehouse Location</label>
      <input type="text" id="coordinator-warehouse-location" class="form-control input-tag" name="warehouseLocation" placeholder="Enter Warehouse Location" readonly required />
    </div>

    <div class="span-full form-subheading">
      <h1>Coordinator Information</h1>
    </div>

    <div class="span-seven">
      <label for="user-name">Coordinator Name</label>
      <input type="text" id="user-name" class="form-control input-tag" name="userName" placeholder="Enter Coordinator Name" required />
    </div>

    <div class="span-six">
      <label for="user-location">Location</label>
      <input type="text" id="user-location" class="form-control input-tag" name="userLocation" placeholder="Enter Location" required />
    </div>

    <div class="span-six">
      <label for="user-department">Department</label>
      <input type="text" id="user-department" class="form-control input-tag" name="userDepartment" placeholder="Enter Department" required />
    </div>

    <div class="span-six">
      <label for="user-contact-no">Contact No</label>
      <input type="text" id="user-contact-no" class="form-control input-tag" name="userContact" placeholder="Enter Contact No" required />
    </div>

    <div class="span-seven">
      <label for="user-email">Email</label>
      <input type="email" id="user-email" class="form-control" name="userEmail" placeholder="Enter Email" required />
    </div>

    <div class="span-full">
      <label for="dispatch-address">Pick Up Address</label>
      <textarea  id="dispatch-address"  class="form-control input-tag"  name="dispatchAddress"  placeholder="Enter Pick Up Address" rows="3" style="border: 1px solid #044A78; resize: none;" required></textarea>
    </div>

    <div class="span-full form-subheading">
      <h1>Pick Up Details</h1>
    </div>

    <div class="span-full form-subheading gap">
      <div class="hardware active">
        <h1>Transport</h1>
      </div>
      <div class="software">
        <h1>Self Pick Up</h1>
      </div>
    </div>       

    <div class="span-full hardware-options">
    <div class="span-five">
      <label for="transport-name">Name</label>
      <input type="text" id="transport-name" class="form-control input-tag" name="transportName" placeholder="Enter Transport Name" />
    </div>

    <div class="span-four">
      <label for="transport-contact">Contact</label>
      <input type="text" id="transport-contact" class="form-control input-tag" name="transportContact" placeholder="Enter Transport Contact" />
    </div>

    <div class="span-five">
      <label for="drop-location">Drop Location 1</label>
      <input type="text" id="drop-location" class="form-control input-tag" name="dropLocation" placeholder="Enter Drop Location 1" />
    </div>

    <div class="span-five">
      <label for="drop-location-2">Drop Location 2</label>
      <input type="text" id="drop-location-2" class="form-control input-tag" name="dropLocation1" placeholder="Enter Drop Location 2" />
    </div>

    <div class="span-five">
      <label for="delivery-mode">Pick Up Mode</label>
      <select name="deliveryMode" id="delivery-mode" class="form-control select-tag">
        <option value="" selected disabled hidden>Select</option>
        <option value="DOOR">DOOR</option>
        <option value="GODOWN">GODOWN</option>
      </select>
    </div>

    <div class="span-five">
      <label for="delivery-location">Pick Up Loc</label>
      <input type="text" id="delivery-location" class="form-control input-tag" name="deliveryLocation" placeholder="Enter Pick Up Location" />
    </div>

    <div class="span-three">
      <label for="payment">Payment</label>
      <select name="vendorPayment" id="payment" class="form-control select-tag">
        <option value="" selected disabled hidden>Select</option>
        <option value="PAY">PAY</option>
        <option value="TO PAY">TO PAY</option>
      </select>
    </div>      
    </div>

    <input type="hidden" name="objectId" id="object-id">

    <div class="span-full software-options">
          <input type="text" id="self-dispatch" class="form-control input-tag span-full" name="SelfDispatch" value="Self Pick Up" />
    </div>

    <div class="span-full btn-grp">
      <button id="vendor-user-submit-btn" class="submit-btn" type="submit">Save Coordinator Details</button>
    </div>
  </form>
</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/selectize/dist/js/standalone/selectize.min.js"></script>

<script>
  const vendorForm = document.getElementById("vendor-form");
  const vendorSubmitBtn = document.getElementById("vendor-submit-btn");
  const vendorUserForm = document.getElementById("vendor-user-form");
  const vendorUserSubmitBtn = document.getElementById("vendor-user-submit-btn");
  let vendorSubmitting = false;
  let vendorUserSubmitting = false;

  if (vendorForm) {
    vendorForm.addEventListener("submit", (e) => {
      if (vendorSubmitting) {
        e.preventDefault();
        return;
      }

      if (!vendorForm.checkValidity()) return;

      vendorSubmitting = true;
      if (vendorSubmitBtn) vendorSubmitBtn.disabled = true;
    });
  }

  if (vendorUserForm) {
    vendorUserForm.addEventListener("submit", (e) => {
      if (vendorUserSubmitting) {
        e.preventDefault();
        return;
      }

      if (!vendorUserForm.checkValidity()) return;

      vendorUserSubmitting = true;
      if (vendorUserSubmitBtn) vendorUserSubmitBtn.disabled = true;
    });
  }
</script>
