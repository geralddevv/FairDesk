<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />
<link href="https://unpkg.com/tabulator-tables@5.6.2/dist/css/tabulator_modern.min.css" rel="stylesheet">
</head>

<body>
  <div class="contain" style="flex-direction: column; padding: 10px; gap: 10px" >
      <style>
        .header-action-btn {
          background-color: #f0f0f0;
          color: #044a78;
          padding: 2px 14px;
          font-size: 14px;
          font-weight: 500;
          border: none;
          cursor: pointer;
          border-radius: 0.5rem;
          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
          transition: all 0.2s ease-in-out;
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .header-action-btn:hover {
          background-color: #e4e4e4;
        }
      </style>
      <div class="indi-head">
        <h1>
          Vendor TTRs
          <% if (typeof vendorUser !== "undefined" && vendorUser && (vendorUser.vendorName || vendorUser.userName)) { %>
            - <%= vendorUser.vendorName || "" %><%= vendorUser.vendorName && vendorUser.userName ? " / " : "" %><%= vendorUser.userName || "" %>
          <% } %>
        </h1>
        <div class="download-btns">
          <% if (typeof vendorUser !== "undefined" && vendorUser) { %>
            <button class="header-action-btn" onclick="window.location.href = '/fairdesk/ttr-vendor/view'">
              <i class="fa-solid fa-list" style="margin-right: 4px"></i> All TTRs
            </button>
          <% } %>
          <div class="download-selector" id="downloadSelector">
            <button class="download-selector__trigger">
              <span>
                <i class="fa-solid fa-file-arrow-down"></i>
                <span class="download-typo">Download</span>
              </span>
              <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
            </button>
            <div class="download-selector__menu" id="downloads">
              <span class="download-selector__option" id="download-pdf">
                <i class="fas fa-file-pdf download-selector__option-icon"></i>
                <span>PDF</span>
              </span>
              <span class="download-selector__option" id="download-xlsx">
                <i class="fas fa-file-excel download-selector__option-icon"></i>
                <span>Excel</span>
              </span>
            </div>
          </div>
      </div>
    </div>

    <div class="table-spinner"><div class="spinner-circle"></div></div>
    <div id="master-table" class="tabulator tabulator-modern"></div>
</div>

  <!-- Tabulator JS -->
  <script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>

  <script id="table-data" type="application/json"><%- JSON.stringify(jsonData || []) %></script>
  <script>
    const tableData = JSON.parse(document.getElementById('table-data').textContent);

    console.log(tableData);

    const table = new Tabulator("#master-table", {
      data: tableData,
      layout: "fitDataTable",
      responsiveLayout: false,
      pagination: "local",
      paginationSize: 30,
      movableColumns: true,
      placeholder: "No data to display",
      columns: [
        {
          title: "",
          formatter: function (cell) {
            const row = cell.getRow().getData();
            if (!row._id) return `<span style="color:#999">N/A</span>`;
            return `
              <button 
                onclick="window.location.href='/fairdesk/ttr-vendor/compare/${row._id}'"
                style="padding:2px 10px;background:#044A78;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;">
                <i class="fa-solid fa-eye"></i>
              </button>
            `;
          }
        },
        {
          title: "Status",
          field: "status",
          hozAlign: "center",
          headerFilter: "input",
          headerFilterPlaceholder: "Filter",
          formatter: function (cell) {
            const val = cell.getValue() || "ACTIVE";
            const isActive = val === "ACTIVE";
            const bg = isActive ? "#28a745" : "#dc3545";
            return `<span style="background:${bg};color:#fff;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;">${val}</span>`;
          }
        },
        {
          title: "Stock",
          field: "stock",
          hozAlign: "center",
          formatter: (cell) => {
            const stock = cell.getValue() ?? "-";
            return `<span style="font-weight:600">${stock}</span>`;
          }
        },        
        { title: "Sample ID", field: "sampleId", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Vendor", field: "vendorName", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Coordinator", field: "userName", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Contact", field: "userContact", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Location", field: "location", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "FS Type", field: "ttrType", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Vendor Type", field: "vendorTtrType", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "FS Color", field: "ttrColor", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Vendor Color", field: "vendorTtrColor", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "FS Code", field: "ttrMaterialCode", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Vendor Code", field: "vendorTtrMaterialCode", headerFilter: "input", headerFilterPlaceholder: "Search" },
        { title: "Minimum Qty", field: "ttrMinQty" },
      ]
    });

    const selector = document.getElementById("downloadSelector");
    const trigger = selector.querySelector(".download-selector__trigger");
    
    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      selector.classList.toggle("download-selector--active");
    });
  
    document.addEventListener("click", () => {
      selector.classList.remove("download-selector--active");
    });
  
    document.getElementById("download-pdf").addEventListener("click", () => {
      table.download("pdf", "vendor_ttr.pdf", {
        orientation: "landscape",
        title: "Vendor TTR Data",
      });
      selector.classList.remove("download-selector--active");
    });
  
    document.getElementById("download-xlsx").addEventListener("click", () => {
      table.download("xlsx", "vendor_ttr.xlsx", {
        sheetName: "Vendor TTR",
      });
      selector.classList.remove("download-selector--active");
    });
  </script>
</body>
