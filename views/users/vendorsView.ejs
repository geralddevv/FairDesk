<% layout('/layout/boilerplate') -%>

<!-- ================= TABULATOR CSS ================= -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
  <div class="indi-head">
    <h1>Vendors</h1>

    <style>
      .header-action-btn {
        background-color: #f0f0f0;
        color: #044a78;
        padding: 2px 14px;
        font-size: 14px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        border-radius: 0.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: all 0.2s ease-in-out;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .header-action-btn:hover {
        background-color: #e4e4e4;
      }
    </style>

    <div style="display: flex; gap: 10px; align-items: center">
      <button class="header-action-btn" onclick="window.location.href = '/fairdesk/form/vendor'">
        <i class="fa-solid fa-plus" style="margin-right: 4px"></i> Vendor
      </button>
      <button class="header-action-btn" onclick="window.location.href = '/fairdesk/form/vendor?tab=user'">
        <i class="fa-solid fa-plus" style="margin-right: 4px"></i> Vendor User
      </button>

      <div class="download-selector" id="downloadSelector">
        <button class="download-selector__trigger">
          <span> <i class="fa-solid fa-file-arrow-down"></i> Download </span>
          <i class="fas fa-chevron-down"></i>
        </button>

        <div class="download-selector__menu">
          <div class="download-selector__option" id="download-pdf"><i class="fas fa-file-pdf"></i> PDF</div>
          <div class="download-selector__option" id="download-xlsx"><i class="fas fa-file-excel"></i> Excel</div>
        </div>
      </div>
    </div>
  </div>

  <div class="table-spinner"><div class="spinner-circle"></div></div>
  <div id="master-table"></div>
</div>

<!-- ================= VENDOR DETAILS POPUP ================= -->
<style>
  .vendor-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
  }

  .vendor-modal {
    background: #f8f9fa;
    border: 1px solid #044a78;
    border-radius: 8px;
    width: 85%;
    max-width: 820px;
    overflow: hidden;
  }

  .vendor-modal-header {
    background: #044a78;
    color: white;
    padding: 6px 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .vendor-modal-title {
    font-size: 1rem;
    font-weight: 600;
  }

  .vendor-modal-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .vendor-action-btn {
    color: #044a78;
    background: #fff;
    padding: 0px 10px;
    font-size: 16px;
    cursor: pointer;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .vendor-action-btn:hover {
    opacity: 0.85;
  }

  .vendor-close {
    cursor: pointer;
    font-size: 1rem;
  }

  .vendor-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
  }

  .vendor-field {
    padding: 6px 8px;
    border-bottom: 1px solid rgba(26, 26, 46, 0.25);
    border-right: 1px solid rgba(26, 26, 46, 0.25);
  }

  .vendor-field:nth-child(2n) {
    border-right: none;
  }

  .vendor-label {
    font-size: 11px;
    color: #6c757d;
  }

  .vendor-value {
    font-size: 13px;
    font-weight: 500;
    color: #044a78;
  }

  @media (max-width: 700px) {
    .vendor-grid {
      grid-template-columns: 1fr;
    }
    .vendor-field {
      border-right: none;
    }
  }
</style>

<div class="vendor-modal-backdrop" id="vendorModal">
  <div class="vendor-modal">
    <div class="vendor-modal-header">
      <div class="vendor-modal-title" id="vendorModalTitle"></div>

      <div class="vendor-modal-actions">
        <a href="#" class="vendor-action-btn" id="vendorEditLink">Edit</a>
        <span class="vendor-close" onclick="closeVendorModal()">&times;</span>
      </div>
    </div>

    <div class="vendor-grid" id="vendorModalBody"></div>
  </div>
</div>

<!-- ================= SCRIPTS ================= -->
<script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/file-saver@2.0.5/dist/FileSaver.min.js"></script>

<script>
  /* ===== Dropdown ===== */
  const downloadSelector = document.getElementById("downloadSelector");
  const triggerBtn = downloadSelector.querySelector(".download-selector__trigger");

  triggerBtn.addEventListener("click", (e) => {
    e.stopPropagation();
    downloadSelector.classList.toggle("download-selector--active");
  });

  document.addEventListener("click", () => {
    downloadSelector.classList.remove("download-selector--active");
  });

  const formatCommodityValue = (commodities) => {
    if (Array.isArray(commodities)) return commodities.filter(Boolean).join(", ");
    return commodities || "-";
  };

  /* ===== Table ===== */
  const tableData = <%- JSON.stringify(jsonData) %>;

  const table = new Tabulator("#master-table", {
    data: tableData,
    layout: "fitColumns",
    pagination: "local",
    paginationSize: 25,
    initialSort: [{ column: "vendorName", dir: "asc" }],

    columns: [
      {
        title: "Vendor Name",
        field: "vendorName",
        minWidth: 240,
        headerFilter: true,

        formatter: (cell) => {
          const row = cell.getRow().getData();
          const hasUsers = Array.isArray(row.users) && row.users.length > 0;
          const color = hasUsers ? "#044a78" : "#dc2626";
          return `<span class="client-name-cell" style="color:${color};text-decoration:underline;text-underline-offset:2px;">${cell.getValue()}</span>`;
        },

        cellClick: (e, cell) => {
          const row = cell.getRow().getData();
          openVendorModal(row.vendorName);
        },
      },
      {
        title: "Status",
        field: "vendorStatus",
        headerSort: true,
        headerFilter: "select",
        headerFilterParams: {
          values: {
            "": "All",
            ACTIVE: "ACTIVE",
            INACTIVE: "INACTIVE",
            BLACKLISTED: "BLACKLISTED",
            OTHERS: "OTHERS",
          },
        },
        width: 120,
        formatter: (cell) => {
          const v = cell.getValue();
          const color = v === "ACTIVE" ? "#28a745" : "#dc3545";
          return `<span style="font-weight:600;color:${color}">${v}</span>`;
        },
      },
      { title: "H/O Location", field: "hoLocation", headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "Warehouse Location", field: "warehouseLocation", headerFilter: "input", headerFilterPlaceholder: "Search" },
      {
        title: "Commodities",
        field: "commodities",
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        formatter: (cell) => formatCommodityValue(cell.getValue()),
      },
      { title: "GST", field: "vendorGst", headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "MSME", field: "vendorMsme", headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "PAN", field: "vendorPan", headerFilter: "input", headerFilterPlaceholder: "Search" },
    ],
  });

  /* ===== POPUP LOGIC ===== */
  async function openVendorModal(vendorName) {
    const res = await fetch(`/fairdesk/form/vendor/${encodeURIComponent(vendorName)}`);
    const vendor = await res.json();
    const editLink = document.getElementById("vendorEditLink");

    document.getElementById("vendorModalTitle").innerText = vendor.vendorName || vendorName;
    if (editLink) {
      editLink.href = vendor._id ? `/fairdesk/vendor/edit/${encodeURIComponent(vendor._id)}` : "#";
      editLink.style.pointerEvents = vendor._id ? "auto" : "none";
      editLink.style.opacity = vendor._id ? "1" : "0.5";
    }

    const fields = [
      ["Vendor ID", vendor.vendorId],
      ["Status", vendor.vendorStatus],
      ["H/O Location", vendor.hoLocation],
      ["Warehouse Location", vendor.warehouseLocation],
      ["Commodities", formatCommodityValue(vendor.commodities)],
      ["GST", vendor.vendorGst],
      ["MSME", vendor.vendorMsme],
      ["Gumasta", vendor.vendorGumasta],
      ["PAN", vendor.vendorPan],
      ["Linked Users", Array.isArray(vendor.users) ? vendor.users.length : 0],
    ];

    const body = document.getElementById("vendorModalBody");
    body.innerHTML = "";

    fields.forEach(([label, value]) => {
      body.innerHTML += `
        <div class="vendor-field">
          <div class="vendor-label">${label}</div>
          <div class="vendor-value">${value || "-"}</div>
        </div>
      `;
    });

    document.getElementById("vendorModal").style.display = "flex";
  }

  function closeVendorModal() {
    document.getElementById("vendorModal").style.display = "none";
  }
</script>
