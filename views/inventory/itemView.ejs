<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<style>
  .tape-details-shell {
    padding: 18px;
    background: linear-gradient(180deg, #eef5fb 0%, #f7f9fc 100%);
  }

  .tape-details-card {
    position: relative;
    background: #fff;
    border-radius: 18px;
    box-shadow: 0 18px 42px rgba(4, 74, 120, 0.12);
    border: 1px solid rgba(4, 74, 120, 0.12);
    overflow: hidden;
  }

  .tape-details-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-end;
    padding: 24px 24px 22px;
    background:
      radial-gradient(circle at top right, rgba(255,255,255,0.16), transparent 34%),
      linear-gradient(135deg, #044a78 0%, #03365a 100%);
    color: #fff;
  }

  .header-copy {
    max-width: 100%;
  }

  .tape-details-header h1 {
    margin: 0;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: 0.2px;
  }

  .header-actions {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .header-action-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.2px;
    backdrop-filter: blur(8px);
    transition: background 0.18s ease;
  }

  .header-action-link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.2);
  }

  .section-title {
    margin: 0 0 14px;
    color: #044a78;
    font-size: 17px;
    font-weight: 700;
  }

  .item-details-box {
    border: 1px solid #e6eaf2;
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
  }

  .item-details-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
  }

  .item-detail {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 8px;
    padding: 4px 6px;
    border-bottom: 1px solid #eef2f7;
    border-right: 1px solid #e5e7eb;
    line-height: 1.2;
  }

  .item-detail-label {
    font-size: 12px;
    color: #6b7280;
  }

  .item-detail-value {
    font-size: 12px;
    color: #111827;
    font-weight: 600;
  }

  .item-detail:nth-child(4n) {
    border-right: none;
  }

  .item-detail:last-child {
    border-bottom: none;
  }

  .item-detail:nth-last-child(-n + 4) {
    border-bottom: none;
  }

  .item-detail:nth-last-child(-n + 4):nth-child(4n) {
    border-right: none;
  }

  .diff-table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid #e6eaf2;
    border-radius: 12px;
    overflow: hidden;
  }

  .diff-table th,
  .diff-table td {
    padding: 10px 12px;
    border-bottom: 1px solid #e6eaf2;
    text-align: left;
    font-size: 13px;
    vertical-align: top;
  }

  .diff-table th {
    background: #f4f7ff;
    color: #044a78;
    font-weight: 700;
  }

  .diff-table tbody tr:last-child td {
    border-bottom: none;
  }

  .diff-table .key-col {
    width: 32%;
    color: #5a6586;
    font-weight: 600;
  }

  .diff-table .resolved {
    font-weight: 700;
    color: #1f2a44;
  }

  .tape-details-body {
    padding: 22px 24px 24px;
  }

  .stock-section {
    margin-top: 18px;
  }

  .stock-summary {
    display: none;
  }

  .stock-table {
    width: 100%;
    display: table;
    table-layout: fixed;
    border-collapse: collapse;
    border: 1px solid #e6eaf2;
    border-radius: 12px;
    overflow: hidden;
  }

  .stock-table th,
  .stock-table td {
    padding: 8px 10px;
    border-bottom: 1px solid #e6eaf2;
    text-align: left;
    font-size: 13px;
  }

  .stock-table th {
    background: #f4f7ff;
    color: #044a78;
    font-weight: 700;
  }

  .stock-table tbody tr:last-child td {
    border-bottom: none;
  }

  .stock-table .qty-col {
    width: 88px;
    max-width: 88px;
    min-width: 88px;
    white-space: nowrap;
    font-weight: 700;
  }

  .stock-table th:first-child,
  .stock-table td:first-child {
    padding-right: 6px;
    width: 20%;
  }

  .stock-table th.qty-col,
  .stock-table td.qty-col {
    padding-left: 4px;
    padding-right: 8px;
  }

  @media (max-width: 1100px) {
    .item-details-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .tape-details-header {
      flex-direction: column;
      align-items: flex-start;
      padding-top: 24px;
    }

    .item-details-grid {
      grid-template-columns: 1fr;
    }

    .item-detail {
      grid-template-columns: 1fr;
      gap: 4px;
      border-right: none;
    }
  }
</style>

<div class="main-content tape-details-shell">
  <div class="tape-details-card">
    <div class="tape-details-header">
      <div class="header-copy">
        <h1><%= pageTitle %></h1>
      </div>
      <div class="header-actions">
        <% if (editUrl) { %>
          <a class="header-action-link" href="<%= editUrl %>">
            <i class="fa-solid fa-pencil"></i>
            <%= editLabel %>
          </a>
        <% } %>
      </div>
    </div>

    <div class="tape-details-body">
      <% if (typeof stockFirst !== 'undefined' && stockFirst && typeof stockInfo !== 'undefined' && stockInfo) { %>
        <div class="stock-section">
          <h3 class="section-title">Stock by Location</h3>
          <table class="stock-table">
            <thead>
              <tr>
                <th>Location</th>
                <th class="qty-col">Stock</th>
              </tr>
            </thead>
            <tbody>
              <% (stockInfo.locations || []).forEach(entry => { %>
                <tr>
                  <td><%= entry.location %></td>
                  <td class="qty-col"><%= entry.qty %></td>
                </tr>
              <% }) %>
              <tr>
                <td><strong>Total</strong></td>
                <td class="qty-col"><strong><%= stockInfo.totalStock ?? 0 %></strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      <% } %>

      <div class="details-section">
        <h3 class="section-title"><%= sectionTitle %></h3>
        <div class="item-details-box">
          <div class="item-details-grid">
            <% (rows || []).forEach((row) => { %>
              <div class="item-detail">
                <div class="item-detail-label"><%= row.label %></div>
                <div class="item-detail-value"><%= row.value %></div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>

      <% if (!(typeof stockFirst !== 'undefined' && stockFirst) && typeof stockInfo !== 'undefined' && stockInfo) { %>
        <div class="stock-section">
          <h3 class="section-title">Stock by Location</h3>
          <table class="stock-table">
            <thead>
              <tr>
                <th>Location</th>
                <th class="qty-col">Stock</th>
              </tr>
            </thead>
            <tbody>
              <% (stockInfo.locations || []).forEach(entry => { %>
                <tr>
                  <td><%= entry.location %></td>
                  <td class="qty-col"><%= entry.qty %></td>
                </tr>
              <% }) %>
              <tr>
                <td><strong>Total</strong></td>
                <td class="qty-col"><strong><%= stockInfo.totalStock ?? 0 %></strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>
